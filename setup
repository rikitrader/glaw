#!/usr/bin/env bash
# GLAW installer — deploys the firm and creates state.
#   ./setup              deploy skills + create state dir
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
GLAW_HOME="${GLAW_HOME:-$HOME/.glaw}"

echo "⚖️  GLAW setup"
echo "   repo: $HERE"

# 1) deploy every sub-skill as a top-level /glaw-* command
echo "→ deploying skills…"
bash "$HERE/bin/glaw-setup"

# 2) state dir
mkdir -p "$GLAW_HOME/tools"
echo "→ state dir: $GLAW_HOME"

# 3) zero-dependency policy
echo "→ zero-dependency mode: no pip/npm installs, no venv build"

# 4) health check
echo "→ health check…"
bash "$HERE/bin/glaw-doctor" 2>/dev/null | tail -3 || true

echo ""
echo "✅ Done. Open a matter with:  /glaw"
echo "   Verify any time with:      bin/glaw-doctor"
