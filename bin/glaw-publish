#!/usr/bin/env python3
"""glaw-publish — zero-dependency local publishing.

Collects matter markdown deliverables and writes local HTML copies plus an index
under <matter>/_published/. No Google Drive, pandoc, weasyprint, or client
libraries are used.

Usage:
  glaw-publish <matter-slug-or-dir> [--folder ignored] [--local-only]
"""
import datetime
import glob
import html
import os
import re
import sys


def md_to_html(text, title):
    out = [f"<!doctype html><meta charset='utf-8'><title>{html.escape(title)}</title>",
           "<style>body{font-family:Helvetica,Arial,sans-serif;max-width:820px;margin:40px auto;line-height:1.5}"
           "h1,h2{text-align:center;text-transform:uppercase}blockquote{border-left:4px solid #999;padding-left:1em;color:#444}"
           "table{border-collapse:collapse;width:100%}td,th{border:1px solid #aaa;padding:6px}</style>"]
    for line in text.splitlines():
        if line.startswith("# "):
            out.append(f"<h1>{html.escape(line[2:].strip())}</h1>")
        elif line.startswith("## "):
            out.append(f"<h2>{html.escape(line[3:].strip())}</h2>")
        elif line.startswith(">"):
            out.append(f"<blockquote>{html.escape(line[1:].strip())}</blockquote>")
        elif line.strip():
            out.append(f"<p>{html.escape(line)}</p>")
    return "\n".join(out) + "\n"


def main():
    a = sys.argv[1:]
    if not a:
        print(__doc__)
        return 1
    target = a[0]
    matter = target if os.path.isdir(target) else os.path.expanduser(f"~/.glaw/matters/{target}")
    if not os.path.isdir(matter):
        print(f"not found: {matter}")
        return 1
    name = os.path.basename(matter.rstrip("/"))
    pub = os.path.join(matter, "_published")
    os.makedirs(pub, exist_ok=True)
    skip_dirs = ("/_published/", "/_extracted/", "/evidence/", "-vault/")
    skip_names = {"matter.md", "parties.md", "index.md"}
    docs = [f for f in sorted(glob.glob(os.path.join(matter, "**", "*.md"), recursive=True))
            if not any(s in f for s in skip_dirs) and os.path.basename(f) not in skip_names]
    if not docs:
        print("no .md deliverables found")
        return 0
    index = [f"# GLAW DELIVERABLES — {name}", "",
             f"_Published {datetime.date.today().isoformat()} in zero-dependency local mode._", "",
             "| Document | HTML | Source |", "|---|---|---|"]
    for src in docs:
        stem = re.sub(r"[^A-Za-z0-9._-]+", "-", os.path.splitext(os.path.basename(src))[0])
        html_path = os.path.join(pub, stem + ".html")
        text = open(src, encoding="utf-8", errors="ignore").read()
        open(html_path, "w", encoding="utf-8").write(md_to_html(text, stem))
        index.append(f"| {os.path.basename(src)} | [{stem}.html]({stem}.html) | {src} |")
        print(f"  wrote {html_path}")
    idx = os.path.join(pub, "index.md")
    open(idx, "w", encoding="utf-8").write("\n".join(index) + "\n")
    print(f"INDEX: {idx}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
