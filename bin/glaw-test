#!/usr/bin/env bash
# glaw-test — per-skill CONTRACT test harness (read-only, ZERO spend, no LLM calls).
# Closes the "breadth >> validation" gap: glaw-doctor smoke-tests parity/refs/tools;
# THIS asserts the contract of EVERY skill (the ~40 personas + stages + orchestrator),
# so a malformed/typo'd/disclaimer-less skill fails CI instead of shipping silently.
#
# Per skill SKILL.md it asserts:
#   1. frontmatter complete: name, version, description, allowed-tools, triggers
#   2. name matches its deployed command (glaw-<dir>, or 'glaw' for the orchestrator)
#   3. a "## When to invoke/use" section exists
#   4. the load-bearing UPL / not-legal-advice line is present (firm hard gate #4)
#   5. allowed-tools is a non-empty list
#   6. an explicit agent identity/soul/posture section exists
#   7. a workflow section ties the seat into the orchestrator
#   8. firm memory is wired through glaw-learnings / ReasoningBank
# Exit 0 = all contracts pass, 1 = at least one violation.
set -uo pipefail
GLAW="${GLAW_SKILL_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
PASS=0; FAILS=0
red(){ printf '  \033[31m✗ %s\033[0m\n' "$1"; FAILS=$((FAILS+1)); }
grn(){ PASS=$((PASS+1)); }

echo "═══ GLAW SKILL-CONTRACT TEST ═══"
total=0
for f in $(find -H "$GLAW" -name SKILL.md | sort); do
  rel="${f#$GLAW/}"
  dir="${rel%/SKILL.md}"
  total=$((total+1))
  errs=()
  for marker in "Identity:" "Soul:"; do
    grep -qF "$marker" "$f" || errs+=("missing identity/soul marker: $marker")
  done
  # Vendored third-party seats under seats/ are deployed non-destructively and follow their
  # OWN upstream conventions — NOT the firm's internal frontmatter/UPL contract. This harness
  # tests firm-authored skills (the personas + stages + orchestrator); deploy parity + the
  # MANIFEST bijection in glaw-doctor already prove every vendored seat resolves. Only the
  # identity/soul posture markers are mandatory for every skill file.
  case "$dir" in seats/*)
    if [ ${#errs[@]} -eq 0 ]; then grn; else
      printf '  %s\n' "$dir"
      for e in "${errs[@]}"; do red "$e"; done
    fi
    continue
    ;;
  esac
  fm=$(awk 'NR==1&&/^---/{p=1;next} p&&/^---/{exit} p' "$f")   # frontmatter block
  for field in name version description allowed-tools triggers; do
    printf '%s\n' "$fm" | grep -q "^${field}:" || errs+=("missing frontmatter: $field")
  done
  # expected deployed name: orchestrator (SKILL.md at root) = glaw; else glaw-<dir basename>
  # (a dir that already carries the glaw- prefix is taken as-is — no double prefix).
  if [ "$dir" = "$rel" ] || [ -z "$dir" ]; then want="glaw"
  else b="$(basename "$dir")"; case "$b" in glaw|glaw-*) want="$b";; *) want="glaw-$b";; esac; fi
  got=$(printf '%s\n' "$fm" | sed -n 's/^name:[[:space:]]*//p' | tr -d '"'"'"' ' | head -1)
  [ "$got" = "$want" ] || errs+=("name '$got' != expected '$want'")
  grep -qiE '^##.*[Ww]hen to (invoke|use)' "$f" || errs+=("no '## When to invoke' section")
  grep -qiE '^##.*(Persona|Identity|Agent identity|Role posture|Posture)' "$f" \
    || errs+=("no explicit agent identity/persona/posture section")
  for marker in "Primary lens:" "Counter-lens:" "Report voice:" "Disagreement posture:" "Memory posture:"; do
    grep -qF "$marker" "$f" || errs+=("missing identity/reporting posture marker: $marker")
  done
  grep -qiE '^##[[:space:]]*Workflow' "$f" || errs+=("no '## Workflow' section")
  grep -qiE 'memory|learnings|ReasoningBank|glaw-learnings|KNOWN DEFECTS|prior defects|self-learning' "$f" \
    || errs+=("no firm-memory / glaw-learnings wiring")
  grep -qiE 'not legal advice|attorney work-product|work-product, not|does not (form|constitute)|UPL' "$f" \
    || errs+=("no UPL / not-legal-advice line (hard gate #4)")
  # allowed-tools must list at least one tool — either a block list ('  - Tool' lines under it)
  # or inline ('allowed-tools: [Tool, ...]'). BSD-awk-safe: POSIX classes only, no \S.
  if printf '%s\n' "$fm" | grep -q '^allowed-tools:'; then
    block=$(printf '%s\n' "$fm" | sed -n '/^allowed-tools:/,/^[a-zA-Z][a-zA-Z-]*:/p')
    nt=$(printf '%s\n' "$block" | grep -cE '^[[:space:]]+-[[:space:]]*[^[:space:]]')
    inline=$(printf '%s\n' "$fm" | grep -cE '^allowed-tools:[[:space:]]*\[[^]]+\]')
    [ "${nt:-0}" -gt 0 ] || [ "${inline:-0}" -gt 0 ] || errs+=("allowed-tools is empty")
  fi
  if [ ${#errs[@]} -eq 0 ]; then grn; else
    printf '  %s\n' "$dir"
    for e in "${errs[@]}"; do red "$e"; done
  fi
done

echo "═══ RESULT ═══"
profile_failures=$(python3 - "$GLAW" <<'PY'
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
sys.path.insert(0, str(root / "lib"))
from glaw_profiles import ADVERSARIAL_PROFILES, COUNCIL_PROFILES, REVIEWER_SKILL_MAP


def skill_name(path):
    in_frontmatter = False
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.strip() == "---":
            if not in_frontmatter:
                in_frontmatter = True
                continue
            break
        if in_frontmatter and line.startswith("name:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""


skills = {}
for path in sorted(root.rglob("SKILL.md")):
    if ".git" in path.parts:
        continue
    name = skill_name(path)
    if name and name not in skills:
        skills[name] = path

required = set()
for rows in (COUNCIL_PROFILES, ADVERSARIAL_PROFILES):
    for names in rows.values():
        required.update(names)

failures = []
for reviewer in sorted(required):
    command = REVIEWER_SKILL_MAP.get(reviewer)
    if not command:
        failures.append(f"{reviewer}: missing reviewer skill mapping")
        continue
    path = skills.get(command)
    if not path:
        failures.append(f"{reviewer}: mapped skill not found: {command}")
        continue
    text = path.read_text(encoding="utf-8", errors="replace")
    for marker in ("Identity:", "Soul:", "Report voice:"):
        if marker not in text:
            failures.append(f"{reviewer}: {command} missing {marker}")

for reviewer in sorted(set(REVIEWER_SKILL_MAP) - required):
    failures.append(f"{reviewer}: stale reviewer skill mapping")

print("\n".join(failures))
PY
)
if [ -n "$profile_failures" ]; then
  while IFS= read -r failure; do red "profile reviewer identity: $failure"; done <<EOF
$profile_failures
EOF
else
  grn
fi
echo "  skills checked: $total   contract checks passed: $PASS   violations: $FAILS"
[ "$FAILS" = 0 ] && { echo "  ALL CONTRACTS PASS ✅"; exit 0; } || { echo "  CONTRACT VIOLATIONS ❌"; exit 1; }
