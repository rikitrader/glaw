#!/usr/bin/env bash
# glaw-tax-tieout — assurance: posted income tax ties to the recomputed provision + deferred roll-forward.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/tax_tieout.py" "$@"
