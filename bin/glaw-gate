#!/usr/bin/env bash
# glaw-gate — code-ENFORCEMENT of the firm's hard gates (was prose-only in SKILL.md).
# A stage transition is BLOCKED unless the gate events required to enter it are present
# in the matter's timeline.jsonl. Fail-closed: if the required event is absent, exit 1.
#
# GATES (mirror CLAUDE.md "Hard gates"):
#   enter strategy  ⇐ intake_complete              (structured intake before work)
#                   ⇐ conflicts_cleared            (gate 1: conflicts before strategy)
#   enter file      ⇐ citations_verified           (gate 2: cites verified before file)
#                   ⇐ adversarial_done             (gate 3: RED→BLUE before file)
#                   ⇐ red_flags_clear              (no critical/high open findings)
#                   ⇐ final_packet_ready           (required council + manifest)
#                   ⇐ chief_approved               (Chief/Council final approval)
#   enter matter-retro ⇐ docket_gate_complete      (deadline review before close-out)
#                      ⇐ docket_done
# For guarded stages, event presence is necessary but not sufficient; the backing ledgers must
# prove the gate state.
#
# Usage:
#   glaw-gate check <target-stage> [slug]   # exit 0 = clear, 1 = blocked
#   glaw-gate status [slug]                 # show every gate's state for the matter
set -uo pipefail
GLAW_HOME="${GLAW_HOME:-$HOME/.glaw}"
MATTERS="$GLAW_HOME/matters"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# stage -> space-separated required timeline events
_required_events() {
  case "$1" in
    strategy) echo "intake_complete conflicts_cleared" ;;
    file)     echo "citations_verified adversarial_done red_flags_clear final_packet_ready chief_approved" ;;
    matter-retro) echo "docket_gate_complete docket_done" ;;
    *)        echo "" ;;   # unguarded transition
  esac
}

_has_event() {  # _has_event <timeline-file> <event>
  [ -f "$1" ] && grep -Eq "\"event\"[[:space:]]*:[[:space:]]*\"$2\"" "$1"
}

_strategy_artifacts_valid() {  # _strategy_artifacts_valid <matter-dir>
  python3 - "$1" <<'PY'
import json
import pathlib
import sys

d = pathlib.Path(sys.argv[1])
intake_path = d / "intake.json"
ethics_path = d / "ethics.json"
try:
    intake = json.loads(intake_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    print("intake.json missing")
    sys.exit(1)
except json.JSONDecodeError:
    print("intake.json is invalid JSON")
    sys.exit(1)
if intake.get("status") != "complete":
    print("intake.json status is not complete")
    sys.exit(1)
try:
    ethics = json.loads(ethics_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    print("ethics.json missing")
    sys.exit(1)
except json.JSONDecodeError:
    print("ethics.json is invalid JSON")
    sys.exit(1)
if ethics.get("status") != "complete":
    print("ethics.json status is not complete")
    sys.exit(1)
if ethics.get("conflicts_status") not in {"cleared", "waived"}:
    print("ethics conflicts_status is not cleared or waived")
    sys.exit(1)
engagement = ethics.get("engagement", {})
if engagement.get("status") != "drafted":
    print("ethics engagement is not drafted")
    sys.exit(1)
PY
}

_file_artifacts_valid() {  # _file_artifacts_valid <matter-dir> <repo-root>
  python3 - "$1" "$2" <<'PY'
import hashlib
import json
import pathlib
import re
import sys

d = pathlib.Path(sys.argv[1])
root = pathlib.Path(sys.argv[2])
sys.path.insert(0, str(root / "lib"))
from glaw_profiles import ADVERSARIAL_PROFILES, COUNCIL_PROFILES, REVIEWER_SKILL_MAP


def read_jsonl(path):
    rows = []
    if not path.exists():
        return rows
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            rows.append(json.loads(line))
        except json.JSONDecodeError:
            print(f"{path.name} contains invalid JSON")
            sys.exit(1)
    return rows


def latest_by(rows, key):
    latest = {}
    for row in rows:
        latest[str(row.get(key, ""))] = row
    return latest


def skill_name(path):
    in_frontmatter = False
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.strip() == "---":
            if not in_frontmatter:
                in_frontmatter = True
                continue
            break
        if in_frontmatter and line.startswith("name:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""


def skill_path_for(command):
    matches = []
    for path in root.rglob("SKILL.md"):
        if ".git" in path.parts:
            continue
        if skill_name(path) == command:
            matches.append(path)
    if not matches:
        return None
    return sorted(matches, key=lambda p: ("seats" in p.relative_to(root).parts, str(p.relative_to(root))))[0]


TEXT_DELIVERABLE_EXTS = {".md", ".html", ".htm", ".txt"}
TEXT_DELIVERABLE_SKIP_NAMES = {
    "matter.md",
    "index.md",
    "final_packet.md",
}
TEXT_DELIVERABLE_SKIP_PARTS = {
    "_published",
    "_extracted",
    "decisions",
    "evidence",
    "source_documents",
    "sources",
}
SOURCE_EVIDENCE_PARTS = {
    "evidence",
    "source_documents",
    "sources",
}
SOURCE_ID_RE = re.compile(r"\bSRC-\d{4}\b")
REQUIRED_GATE_ARTIFACTS = (
    "intake.json",
    "ethics.json",
    "citations.jsonl",
    "council.jsonl",
    "adversarial.jsonl",
)
OPTIONAL_GATE_ARTIFACTS = (
    "red_flags.jsonl",
)
REPORT_REQUIRED_MARKERS = (
    "Owner:",
    "Report voice:",
    "Findings:",
    "Evidence:",
    "Red flags:",
    "Sign-off conditions:",
)


def is_external_text_deliverable(path):
    if path.suffix.lower() not in TEXT_DELIVERABLE_EXTS:
        return False
    if path.name in TEXT_DELIVERABLE_SKIP_NAMES:
        return False
    return not bool(set(path.relative_to(d).parts) & TEXT_DELIVERABLE_SKIP_PARTS)


def is_source_evidence(path):
    if not path.is_file():
        return False
    return bool(set(path.relative_to(d).parts) & SOURCE_EVIDENCE_PARTS)


def has_upl_footer(text):
    lower = text.lower()
    work_product = "attorney work-product" in lower or "work-product" in lower
    no_advice = "not legal advice" in lower or "not legal, tax, or accounting advice" in lower
    return work_product and no_advice


def sha256_file(path):
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def source_evidence_manifest(paths):
    return [
        {
            "id": f"SRC-{idx:04d}",
            "path": str(path.relative_to(d)),
            "sha256": sha256_file(path),
        }
        for idx, path in enumerate(sorted(paths), start=1)
    ]


def reviewer_identity_manifest(profile):
    required = [("council", name) for name in COUNCIL_PROFILES.get(profile, ())]
    required.extend(("adversarial", name) for name in ADVERSARIAL_PROFILES.get(profile, ()))
    rows = []
    for kind, name in required:
        command = REVIEWER_SKILL_MAP.get(name, "")
        missing = []
        path = skill_path_for(command) if command else None
        text = path.read_text(encoding="utf-8", errors="replace") if path else ""
        if not command:
            missing.append("reviewer skill mapping")
        if not path:
            missing.append("skill file")
        if "Identity:" not in text:
            missing.append("Identity:")
        if "Soul:" not in text:
            missing.append("Soul:")
        if "Report voice:" not in text:
            missing.append("Report voice:")
        rows.append({
            "kind": kind,
            "name": name,
            "skill": command,
            "path": str(path.relative_to(root)) if path else "",
            "sha256": sha256_file(path) if path else "",
            "status": "pass" if not missing else "fail",
            "missing": missing,
        })
    return rows


def report_quality(path, source_manifest):
    text = path.read_text(encoding="utf-8", errors="replace")
    missing = [marker for marker in REPORT_REQUIRED_MARKERS if marker.lower() not in text.lower()]
    source_ids = [item["id"] for item in source_manifest]
    cited_sources = [sid for sid in source_ids if sid in text]
    if not source_ids:
        missing.append("source evidence manifest")
    elif not cited_sources:
        missing.append("source evidence id (SRC-####)")
    return {
        "path": str(path.relative_to(d)),
        "status": "pass" if not missing else "fail",
        "missing_markers": missing,
        "cited_source_ids": cited_sources,
    }


def review_evidence_manifest(council_rows, adversarial_rows, profile, source_manifest):
    source_ids = [item["id"] for item in source_manifest]
    rows = []
    latest_council = latest_by(council_rows, "role")
    for role in COUNCIL_PROFILES.get(profile, ()):
        row = latest_council.get(role, {})
        evidence = str(row.get("evidence", ""))
        cited = [sid for sid in source_ids if sid in evidence]
        missing = []
        if not row:
            missing.append("review row")
        if not evidence.strip():
            missing.append("evidence")
        if not cited:
            missing.append("source evidence id (SRC-####)")
        rows.append({
            "kind": "council",
            "name": role,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "cited_source_ids": cited,
        })
    latest_adversarial = latest_by(adversarial_rows, "lens")
    for lens in ADVERSARIAL_PROFILES.get(profile, ()):
        row = latest_adversarial.get(lens, {})
        evidence = str(row.get("evidence", ""))
        cited = [sid for sid in source_ids if sid in evidence]
        missing = []
        if not row:
            missing.append("review row")
        if not evidence.strip():
            missing.append("evidence")
        if not cited:
            missing.append("source evidence id (SRC-####)")
        rows.append({
            "kind": "adversarial",
            "name": lens,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "cited_source_ids": cited,
        })
    return rows


def red_flag_resolution_manifest(red_flags, source_manifest):
    source_ids = [item["id"] for item in source_manifest]
    rows = []
    for flag in red_flags:
        severity = str(flag.get("severity", "")).lower()
        if severity not in {"critical", "high"}:
            continue
        if flag.get("status", "open") != "resolved":
            continue
        evidence = str(flag.get("resolution_evidence", ""))
        cited = [sid for sid in source_ids if sid in evidence]
        syntactic = sorted(set(SOURCE_ID_RE.findall(evidence)))
        missing = []
        if not evidence.strip():
            missing.append("resolution evidence")
        if not syntactic:
            missing.append("source evidence id (SRC-####)")
        elif not cited:
            missing.append("current source evidence id")
        rows.append({
            "id": flag.get("id", ""),
            "severity": severity,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "cited_source_ids": cited,
            "referenced_source_ids": syntactic,
        })
    return rows


def decision_hash(row):
    payload = dict(row)
    payload.pop("decision_hash", None)
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def row_hash(row):
    payload = dict(row)
    payload.pop("row_hash", None)
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def validate_row_hashes(rows, ledger_name):
    failures = []
    for idx, row in enumerate(rows, start=1):
        expected = row.get("row_hash")
        if not expected:
            failures.append(f"{ledger_name}:{idx} missing row_hash")
        elif expected != row_hash(row):
            failures.append(f"{ledger_name}:{idx} row_hash mismatch")
    if failures:
        print("review ledger row hash failure: " + "; ".join(failures))
        sys.exit(1)


p = d / "final_packet.json"
if not p.exists():
    print("final_packet.json missing")
    sys.exit(1)
try:
    packet = json.loads(p.read_text(encoding="utf-8"))
except json.JSONDecodeError:
    print("final_packet.json is invalid JSON")
    sys.exit(1)
if packet.get("status") != "ready":
    print("final_packet.json status is not ready")
    sys.exit(1)
profile = packet.get("workflow_profile") or "hybrid"
if profile not in COUNCIL_PROFILES or profile not in ADVERSARIAL_PROFILES:
    print(f"unknown workflow profile: {profile}")
    sys.exit(1)
packet_generated_at = packet.get("generated_at", "")
if not packet_generated_at:
    print("final_packet.json missing generated_at")
    sys.exit(1)
packet_sha256 = sha256_file(p)
missing = [k for k, v in packet.get("gates", {}).items() if not v]
if missing:
    print("final_packet.json has uncleared gate(s): " + ", ".join(missing))
    sys.exit(1)

deliverables = [p for p in sorted(d.rglob("*")) if p.is_file() and is_external_text_deliverable(p)]
if not deliverables:
    print("no current external text deliverable")
    sys.exit(1)
missing_upl = []
for doc in deliverables:
    text = doc.read_text(encoding="utf-8", errors="replace")
    if not has_upl_footer(text):
        missing_upl.append(str(doc.relative_to(d)))
if missing_upl:
    print("current deliverable(s) missing UPL footer: " + ", ".join(missing_upl))
    sys.exit(1)
expected_source_manifest = packet.get("source_evidence_manifest") or []
if not expected_source_manifest:
    print("final_packet.json missing source_evidence_manifest")
    sys.exit(1)
current_source_manifest = source_evidence_manifest(
    [p for p in d.rglob("*") if is_source_evidence(p)]
)
if expected_source_manifest != current_source_manifest:
    print("current source evidence manifest does not match final_packet.json")
    sys.exit(1)
expected_review_evidence_manifest = packet.get("senior_review_evidence_manifest") or []
if not expected_review_evidence_manifest:
    print("final_packet.json missing senior_review_evidence_manifest")
    sys.exit(1)
council_rows_for_evidence = [r for r in read_jsonl(d / "council.jsonl") if r.get("profile") == profile]
adversarial_rows_for_evidence = [r for r in read_jsonl(d / "adversarial.jsonl") if r.get("profile") == profile]
current_review_evidence_manifest = review_evidence_manifest(
    council_rows_for_evidence,
    adversarial_rows_for_evidence,
    profile,
    current_source_manifest,
)
if expected_review_evidence_manifest != current_review_evidence_manifest:
    print("current senior review evidence manifest does not match final_packet.json")
    sys.exit(1)
failing_review_evidence = [
    f"{item['kind']}:{item['name']} missing {', '.join(item['missing'])}"
    for item in current_review_evidence_manifest
    if item.get("status") != "pass"
]
if failing_review_evidence:
    print("current senior review(s) fail source evidence IDs: " + "; ".join(failing_review_evidence))
    sys.exit(1)
red_flag_rows_for_evidence = read_jsonl(d / "red_flags.jsonl")
expected_red_flag_resolution_manifest = packet.get("red_flag_resolution_evidence_manifest")
if expected_red_flag_resolution_manifest is None:
    print("final_packet.json missing red_flag_resolution_evidence_manifest")
    sys.exit(1)
current_red_flag_resolution_manifest = red_flag_resolution_manifest(
    red_flag_rows_for_evidence,
    current_source_manifest,
)
if expected_red_flag_resolution_manifest != current_red_flag_resolution_manifest:
    print("current red flag resolution evidence manifest does not match final_packet.json")
    sys.exit(1)
failing_red_flag_resolutions = [
    f"{item['id']} missing {', '.join(item['missing'])}"
    for item in current_red_flag_resolution_manifest
    if item.get("status") != "pass"
]
if failing_red_flag_resolutions:
    print("current red flag resolution(s) fail source evidence IDs: " + "; ".join(failing_red_flag_resolutions))
    sys.exit(1)
expected_reviewer_identity_manifest = packet.get("reviewer_identity_manifest") or []
if not expected_reviewer_identity_manifest:
    print("final_packet.json missing reviewer_identity_manifest")
    sys.exit(1)
current_reviewer_identity_manifest = reviewer_identity_manifest(profile)
if expected_reviewer_identity_manifest != current_reviewer_identity_manifest:
    print("current reviewer identity manifest does not match final_packet.json")
    sys.exit(1)
failing_reviewer_identity = [
    f"{item['kind']}:{item['name']} missing {', '.join(item['missing'])}"
    for item in current_reviewer_identity_manifest
    if item.get("status") != "pass"
]
if failing_reviewer_identity:
    print("current reviewer identity manifest is incomplete: " + "; ".join(failing_reviewer_identity))
    sys.exit(1)
expected_report_markers = packet.get("report_quality_required_markers") or []
if expected_report_markers != list(REPORT_REQUIRED_MARKERS):
    print("final_packet.json report quality marker set is missing or stale")
    sys.exit(1)
expected_report_manifest = packet.get("report_quality_manifest") or []
if not expected_report_manifest:
    print("final_packet.json missing report_quality_manifest")
    sys.exit(1)
current_report_manifest = [report_quality(doc, current_source_manifest) for doc in deliverables]
if expected_report_manifest != current_report_manifest:
    print("current report quality manifest does not match final_packet.json")
    sys.exit(1)
failing_reports = [
    f"{item['path']} missing {', '.join(item['missing_markers'])}"
    for item in current_report_manifest
    if item.get("status") != "pass"
]
if failing_reports:
    print("current deliverable(s) fail professional report markers: " + "; ".join(failing_reports))
    sys.exit(1)
expected_hashes = packet.get("external_text_deliverable_hashes") or {}
if not expected_hashes:
    print("final_packet.json missing external_text_deliverable_hashes")
    sys.exit(1)
current_hashes = {
    str(doc.relative_to(d)): sha256_file(doc)
    for doc in deliverables
}
missing_from_disk = sorted(set(expected_hashes) - set(current_hashes))
new_since_packet = sorted(set(current_hashes) - set(expected_hashes))
changed_since_packet = sorted(
    path for path, digest in expected_hashes.items()
    if path in current_hashes and current_hashes[path] != digest
)
if missing_from_disk or new_since_packet or changed_since_packet:
    parts = []
    if missing_from_disk:
        parts.append("missing: " + ", ".join(missing_from_disk))
    if new_since_packet:
        parts.append("new: " + ", ".join(new_since_packet))
    if changed_since_packet:
        parts.append("changed: " + ", ".join(changed_since_packet))
    print("current deliverables do not match final_packet.json: " + "; ".join(parts))
    sys.exit(1)

expected_gate_hashes = packet.get("gate_artifact_hashes") or {}
if not expected_gate_hashes:
    print("final_packet.json missing gate_artifact_hashes")
    sys.exit(1)
missing_gate_hashes = sorted(set(REQUIRED_GATE_ARTIFACTS) - set(expected_gate_hashes))
if missing_gate_hashes:
    print("final_packet.json missing gate artifact hash(es): " + ", ".join(missing_gate_hashes))
    sys.exit(1)
known_gate_artifacts = REQUIRED_GATE_ARTIFACTS + OPTIONAL_GATE_ARTIFACTS
current_gate_hashes = {}
for name in known_gate_artifacts:
    path = d / name
    if path.exists():
        current_gate_hashes[name] = sha256_file(path)
missing_gate_artifacts = sorted(set(expected_gate_hashes) - set(current_gate_hashes))
new_gate_artifacts = sorted(set(current_gate_hashes) - set(expected_gate_hashes))
changed_gate_artifacts = sorted(
    name for name, digest in expected_gate_hashes.items()
    if name in current_gate_hashes and current_gate_hashes[name] != digest
)
if missing_gate_artifacts or new_gate_artifacts or changed_gate_artifacts:
    parts = []
    if missing_gate_artifacts:
        parts.append("missing: " + ", ".join(missing_gate_artifacts))
    if new_gate_artifacts:
        parts.append("new: " + ", ".join(new_gate_artifacts))
    if changed_gate_artifacts:
        parts.append("changed: " + ", ".join(changed_gate_artifacts))
    print("current gate artifacts do not match final_packet.json: " + "; ".join(parts))
    sys.exit(1)

red_flags = d / "red_flags.jsonl"
if red_flags.exists():
    blocking = []
    for row in read_jsonl(red_flags):
        if row.get("status", "open") != "resolved" and str(row.get("severity", "")).lower() in {"critical", "high"}:
            blocking.append(row.get("id") or row.get("finding") or "unnamed")
    if blocking:
        print("current blocking red flag(s): " + ", ".join(str(x) for x in blocking))
        sys.exit(1)

citations = d / "citations.jsonl"
if not citations.exists():
    print("citations.jsonl missing")
    sys.exit(1)
citation_rows = read_jsonl(citations)
validate_row_hashes(citation_rows, "citations.jsonl")
latest_citations = latest_by(citation_rows, "id")
if not latest_citations:
    print("citations.jsonl has no citation rows")
    sys.exit(1)
blocking_citations = []
for cid, row in latest_citations.items():
    status = str(row.get("status", "")).lower()
    if not cid or status in {"pending", "needs-substitute", "struck", "weak"} or (status == "verified" and not row.get("source_url")):
        blocking_citations.append(cid or row.get("authority") or "unnamed")
if blocking_citations:
    print("current blocking citation(s): " + ", ".join(str(x) for x in blocking_citations))
    sys.exit(1)

council = d / "council.jsonl"
if not council.exists():
    print("council.jsonl missing")
    sys.exit(1)
council_rows = read_jsonl(council)
validate_row_hashes(council_rows, "council.jsonl")
latest_council = latest_by([r for r in council_rows if r.get("profile") == profile], "role")
blocking_council = []
for role in COUNCIL_PROFILES[profile]:
    row = latest_council.get(role)
    if not row:
        blocking_council.append(role)
        continue
    if row.get("decision") != "approve" or not str(row.get("evidence", "")).strip():
        blocking_council.append(role)
if blocking_council:
    print("current blocking council role(s): " + ", ".join(str(x) for x in blocking_council))
    sys.exit(1)

adversarial = d / "adversarial.jsonl"
if not adversarial.exists():
    print("adversarial.jsonl missing")
    sys.exit(1)
adversarial_rows = read_jsonl(adversarial)
validate_row_hashes(adversarial_rows, "adversarial.jsonl")
latest_adversarial = latest_by([r for r in adversarial_rows if r.get("profile") == profile], "lens")
blocking_adversarial = []
for lens in ADVERSARIAL_PROFILES[profile]:
    row = latest_adversarial.get(lens)
    if not row:
        blocking_adversarial.append(lens)
        continue
    if row.get("decision") != "survive" or not str(row.get("evidence", "")).strip():
        blocking_adversarial.append(lens)
if blocking_adversarial:
    print("current blocking adversarial lens(es): " + ", ".join(str(x) for x in blocking_adversarial))
    sys.exit(1)

decisions = d / "decisions.jsonl"
if not decisions.exists():
    print("decisions.jsonl missing")
    sys.exit(1)
latest_final = None
latest_packet_generated_at = ""
latest_packet_sha256 = ""
latest_final_row = None
for line in decisions.read_text(encoding="utf-8", errors="replace").splitlines():
    if not line.strip():
        continue
    try:
        row = json.loads(line)
    except json.JSONDecodeError:
        continue
    if row.get("final_gate") in {"approved", "denied"}:
        latest_final = row.get("final_gate")
        latest_packet_generated_at = row.get("approved_packet_generated_at", "")
        latest_packet_sha256 = row.get("approved_packet_sha256", "")
        latest_final_row = row
if latest_final != "approved":
    print("latest Chief final decision is not approved")
    sys.exit(1)
if latest_packet_generated_at != packet_generated_at:
    print("latest Chief approval does not match current final_packet.json generated_at")
    sys.exit(1)
if not latest_packet_sha256:
    print("latest Chief approval missing approved_packet_sha256")
    sys.exit(1)
if latest_packet_sha256 != packet_sha256:
    print("latest Chief approval does not match current final_packet.json sha256")
    sys.exit(1)
if not latest_final_row:
    print("latest Chief approval row missing")
    sys.exit(1)
approval_missing = []
for key in ("score", "grade", "rationale"):
    if not str(latest_final_row.get(key, "")).strip():
        approval_missing.append(key)
if not latest_final_row.get("top_risks"):
    approval_missing.append("top_risks")
if not latest_final_row.get("conditions"):
    approval_missing.append("conditions")
if approval_missing:
    print("latest Chief approval lacks complete sign-off field(s): " + ", ".join(approval_missing))
    sys.exit(1)
expected_decision_hash = str(latest_final_row.get("decision_hash", ""))
if not expected_decision_hash:
    print("latest Chief approval missing decision_hash")
    sys.exit(1)
if expected_decision_hash != decision_hash(latest_final_row):
    print("latest Chief approval decision_hash does not match current decision row")
    sys.exit(1)
PY
}

_retro_artifacts_valid() {  # _retro_artifacts_valid <matter-dir>
  python3 - "$1" <<'PY'
import json
import pathlib
import sys

d = pathlib.Path(sys.argv[1])
docket = d / "docket.jsonl"
open_deadlines = 0
if docket.exists():
    for line in docket.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            row = json.loads(line)
        except json.JSONDecodeError:
            print("docket.jsonl contains invalid JSON")
            sys.exit(1)
        if row.get("due") and row.get("status", "open") != "closed":
            open_deadlines += 1
if open_deadlines:
    sys.exit(0)
record_path = d / "docket_gate.json"
if not record_path.exists():
    print("no open docket deadlines and no docket_gate.json")
    sys.exit(1)
try:
    record = json.loads(record_path.read_text(encoding="utf-8"))
except json.JSONDecodeError:
    print("docket_gate.json is invalid JSON")
    sys.exit(1)
if record.get("status") != "no_deadlines" or not record.get("rationale"):
    print("docket_gate.json lacks a no-deadlines rationale")
    sys.exit(1)
PY
}

_slug() { local s="${1:-}"; [ -n "$s" ] && { echo "$s"; return; }; [ -f "$GLAW_HOME/.active" ] && cat "$GLAW_HOME/.active" || echo ""; }

action="${1:-status}"; shift || true

case "$action" in
  check)
    target="${1:-}"; slug="$(_slug "${2:-}")"
    [ -z "$target" ] && { echo "usage: glaw-gate check <stage> [slug]"; exit 2; }
    [ -z "$slug" ] && { echo "GATE: no active matter"; exit 2; }
    tl="$MATTERS/$slug/timeline.jsonl"
    req="$(_required_events "$target")"
    [ -z "$req" ] && { echo "GATE CLEAR: entering '$target' has no prerequisite gate"; exit 0; }
    missing=""
    for ev in $req; do _has_event "$tl" "$ev" || missing="$missing $ev"; done
    if [ -n "$missing" ]; then
      echo "GATE BLOCKED: cannot enter '$target' for [$slug] — missing required gate event(s):$missing"
      echo "  satisfy by running the owning gate command, not by hand-logging events."
      exit 1
    fi
    if [ "$target" = "strategy" ] && ! artifact_msg="$(_strategy_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "GATE BLOCKED: cannot enter 'strategy' for [$slug] — $artifact_msg"
      exit 1
    fi
    if [ "$target" = "file" ] && ! artifact_msg="$(_file_artifacts_valid "$MATTERS/$slug" "$ROOT" 2>&1)"; then
      echo "GATE BLOCKED: cannot enter 'file' for [$slug] — $artifact_msg"
      exit 1
    fi
    if [ "$target" = "matter-retro" ] && ! artifact_msg="$(_retro_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "GATE BLOCKED: cannot enter 'matter-retro' for [$slug] — $artifact_msg"
      exit 1
    fi
    echo "GATE CLEAR: '$target' prerequisites satisfied ($req)"
    exit 0 ;;
  status)
    slug="$(_slug "${1:-}")"
    [ -z "$slug" ] && { echo "GATE: no active matter"; exit 2; }
    tl="$MATTERS/$slug/timeline.jsonl"
    echo "═══ GATE STATUS — $slug ═══"
    for pair in "intake_complete:before strategy" "conflicts_cleared:before strategy" "citations_verified:before file" "adversarial_done:before file" "red_flags_clear:before file" "final_packet_ready:before file" "chief_approved:before file" "docket_gate_complete:before matter-retro" "docket_done:before matter-retro"; do
      ev="${pair%%:*}"; desc="${pair#*:}"
      if _has_event "$tl" "$ev"; then echo "  ✅ $ev ($desc)"; else echo "  ❌ $ev ($desc) — NOT yet cleared"; fi
    done
    if artifact_msg="$(_file_artifacts_valid "$MATTERS/$slug" "$ROOT" 2>&1)"; then
      echo "  ✅ file_artifacts_verified (before file)"
    else
      echo "  ❌ file_artifacts_verified (before file) — $artifact_msg"
    fi
    if artifact_msg="$(_strategy_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "  ✅ strategy_artifacts_verified (before strategy)"
    else
      echo "  ❌ strategy_artifacts_verified (before strategy) — $artifact_msg"
    fi
    if artifact_msg="$(_retro_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "  ✅ docket_artifacts_verified (before matter-retro)"
    else
      echo "  ❌ docket_artifacts_verified (before matter-retro) — $artifact_msg"
    fi ;;
  *) echo "usage: glaw-gate check <stage> [slug] | status [slug]"; exit 2 ;;
esac
