#!/usr/bin/env bash
# glaw-gate — code-ENFORCEMENT of the firm's hard gates (was prose-only in SKILL.md).
# A stage transition is BLOCKED unless the gate events required to enter it are present
# in the matter's timeline.jsonl. Fail-closed: if the required event is absent, exit 1.
#
# GATES (mirror CLAUDE.md "Hard gates"):
#   enter strategy  ⇐ intake_complete              (structured intake before work)
#                   ⇐ conflicts_cleared            (gate 1: conflicts before strategy)
#   enter file      ⇐ citations_verified           (gate 2: cites verified before file)
#                   ⇐ adversarial_done             (gate 3: RED→BLUE before file)
#                   ⇐ red_flags_clear              (no critical/high open findings)
#                   ⇐ final_packet_ready           (required council + manifest)
#                   ⇐ chief_approved               (Chief/Council final approval)
#   enter matter-retro ⇐ docket_gate_complete      (deadline review before close-out)
#                      ⇐ docket_done
# For guarded stages, event presence is necessary but not sufficient; the backing ledgers must
# prove the gate state.
#
# Usage:
#   glaw-gate check <target-stage> [slug]   # exit 0 = clear, 1 = blocked
#   glaw-gate status [slug]                 # show every gate's state for the matter
set -uo pipefail
GLAW_HOME="${GLAW_HOME:-$HOME/.glaw}"
MATTERS="$GLAW_HOME/matters"

# stage -> space-separated required timeline events
_required_events() {
  case "$1" in
    strategy) echo "intake_complete conflicts_cleared" ;;
    file)     echo "citations_verified adversarial_done red_flags_clear final_packet_ready chief_approved" ;;
    matter-retro) echo "docket_gate_complete docket_done" ;;
    *)        echo "" ;;   # unguarded transition
  esac
}

_has_event() {  # _has_event <timeline-file> <event>
  [ -f "$1" ] && grep -Eq "\"event\"[[:space:]]*:[[:space:]]*\"$2\"" "$1"
}

_strategy_artifacts_valid() {  # _strategy_artifacts_valid <matter-dir>
  python3 - "$1" <<'PY'
import json
import pathlib
import sys

d = pathlib.Path(sys.argv[1])
intake_path = d / "intake.json"
ethics_path = d / "ethics.json"
try:
    intake = json.loads(intake_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    print("intake.json missing")
    sys.exit(1)
except json.JSONDecodeError:
    print("intake.json is invalid JSON")
    sys.exit(1)
if intake.get("status") != "complete":
    print("intake.json status is not complete")
    sys.exit(1)
try:
    ethics = json.loads(ethics_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    print("ethics.json missing")
    sys.exit(1)
except json.JSONDecodeError:
    print("ethics.json is invalid JSON")
    sys.exit(1)
if ethics.get("status") != "complete":
    print("ethics.json status is not complete")
    sys.exit(1)
if ethics.get("conflicts_status") not in {"cleared", "waived"}:
    print("ethics conflicts_status is not cleared or waived")
    sys.exit(1)
engagement = ethics.get("engagement", {})
if engagement.get("status") != "drafted":
    print("ethics engagement is not drafted")
    sys.exit(1)
PY
}

_file_artifacts_valid() {  # _file_artifacts_valid <matter-dir>
  python3 - "$1" <<'PY'
import json
import pathlib
import sys

d = pathlib.Path(sys.argv[1])
p = d / "final_packet.json"
if not p.exists():
    print("final_packet.json missing")
    sys.exit(1)
try:
    packet = json.loads(p.read_text(encoding="utf-8"))
except json.JSONDecodeError:
    print("final_packet.json is invalid JSON")
    sys.exit(1)
if packet.get("status") != "ready":
    print("final_packet.json status is not ready")
    sys.exit(1)
packet_generated_at = packet.get("generated_at", "")
if not packet_generated_at:
    print("final_packet.json missing generated_at")
    sys.exit(1)
missing = [k for k, v in packet.get("gates", {}).items() if not v]
if missing:
    print("final_packet.json has uncleared gate(s): " + ", ".join(missing))
    sys.exit(1)

red_flags = d / "red_flags.jsonl"
if red_flags.exists():
    blocking = []
    for line in red_flags.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            row = json.loads(line)
        except json.JSONDecodeError:
            print("red_flags.jsonl contains invalid JSON")
            sys.exit(1)
        if row.get("status", "open") != "resolved" and str(row.get("severity", "")).lower() in {"critical", "high"}:
            blocking.append(row.get("id") or row.get("finding") or "unnamed")
    if blocking:
        print("current blocking red flag(s): " + ", ".join(str(x) for x in blocking))
        sys.exit(1)

citations = d / "citations.jsonl"
if not citations.exists():
    print("citations.jsonl missing")
    sys.exit(1)
latest_citations = {}
for line in citations.read_text(encoding="utf-8", errors="replace").splitlines():
    if not line.strip():
        continue
    try:
        row = json.loads(line)
    except json.JSONDecodeError:
        print("citations.jsonl contains invalid JSON")
        sys.exit(1)
    latest_citations[str(row.get("id", ""))] = row
if not latest_citations:
    print("citations.jsonl has no citation rows")
    sys.exit(1)
blocking_citations = []
for cid, row in latest_citations.items():
    status = str(row.get("status", "")).lower()
    if not cid or status in {"pending", "needs-substitute", "struck", "weak"} or (status == "verified" and not row.get("source_url")):
        blocking_citations.append(cid or row.get("authority") or "unnamed")
if blocking_citations:
    print("current blocking citation(s): " + ", ".join(str(x) for x in blocking_citations))
    sys.exit(1)

decisions = d / "decisions.jsonl"
if not decisions.exists():
    print("decisions.jsonl missing")
    sys.exit(1)
latest_final = None
latest_packet_generated_at = ""
for line in decisions.read_text(encoding="utf-8", errors="replace").splitlines():
    if not line.strip():
        continue
    try:
        row = json.loads(line)
    except json.JSONDecodeError:
        continue
    if row.get("final_gate") in {"approved", "denied"}:
        latest_final = row.get("final_gate")
        latest_packet_generated_at = row.get("approved_packet_generated_at", "")
if latest_final != "approved":
    print("latest Chief final decision is not approved")
    sys.exit(1)
if latest_packet_generated_at != packet_generated_at:
    print("latest Chief approval does not match current final_packet.json generated_at")
    sys.exit(1)
PY
}

_retro_artifacts_valid() {  # _retro_artifacts_valid <matter-dir>
  python3 - "$1" <<'PY'
import json
import pathlib
import sys

d = pathlib.Path(sys.argv[1])
docket = d / "docket.jsonl"
open_deadlines = 0
if docket.exists():
    for line in docket.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            row = json.loads(line)
        except json.JSONDecodeError:
            print("docket.jsonl contains invalid JSON")
            sys.exit(1)
        if row.get("due") and row.get("status", "open") != "closed":
            open_deadlines += 1
if open_deadlines:
    sys.exit(0)
record_path = d / "docket_gate.json"
if not record_path.exists():
    print("no open docket deadlines and no docket_gate.json")
    sys.exit(1)
try:
    record = json.loads(record_path.read_text(encoding="utf-8"))
except json.JSONDecodeError:
    print("docket_gate.json is invalid JSON")
    sys.exit(1)
if record.get("status") != "no_deadlines" or not record.get("rationale"):
    print("docket_gate.json lacks a no-deadlines rationale")
    sys.exit(1)
PY
}

_slug() { local s="${1:-}"; [ -n "$s" ] && { echo "$s"; return; }; [ -f "$GLAW_HOME/.active" ] && cat "$GLAW_HOME/.active" || echo ""; }

action="${1:-status}"; shift || true

case "$action" in
  check)
    target="${1:-}"; slug="$(_slug "${2:-}")"
    [ -z "$target" ] && { echo "usage: glaw-gate check <stage> [slug]"; exit 2; }
    [ -z "$slug" ] && { echo "GATE: no active matter"; exit 2; }
    tl="$MATTERS/$slug/timeline.jsonl"
    req="$(_required_events "$target")"
    [ -z "$req" ] && { echo "GATE CLEAR: entering '$target' has no prerequisite gate"; exit 0; }
    missing=""
    for ev in $req; do _has_event "$tl" "$ev" || missing="$missing $ev"; done
    if [ -n "$missing" ]; then
      echo "GATE BLOCKED: cannot enter '$target' for [$slug] — missing required gate event(s):$missing"
      echo "  satisfy by running the owning gate command, not by hand-logging events."
      exit 1
    fi
    if [ "$target" = "strategy" ] && ! artifact_msg="$(_strategy_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "GATE BLOCKED: cannot enter 'strategy' for [$slug] — $artifact_msg"
      exit 1
    fi
    if [ "$target" = "file" ] && ! artifact_msg="$(_file_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "GATE BLOCKED: cannot enter 'file' for [$slug] — $artifact_msg"
      exit 1
    fi
    if [ "$target" = "matter-retro" ] && ! artifact_msg="$(_retro_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "GATE BLOCKED: cannot enter 'matter-retro' for [$slug] — $artifact_msg"
      exit 1
    fi
    echo "GATE CLEAR: '$target' prerequisites satisfied ($req)"
    exit 0 ;;
  status)
    slug="$(_slug "${1:-}")"
    [ -z "$slug" ] && { echo "GATE: no active matter"; exit 2; }
    tl="$MATTERS/$slug/timeline.jsonl"
    echo "═══ GATE STATUS — $slug ═══"
    for pair in "intake_complete:before strategy" "conflicts_cleared:before strategy" "citations_verified:before file" "adversarial_done:before file" "red_flags_clear:before file" "final_packet_ready:before file" "chief_approved:before file" "docket_gate_complete:before matter-retro" "docket_done:before matter-retro"; do
      ev="${pair%%:*}"; desc="${pair#*:}"
      if _has_event "$tl" "$ev"; then echo "  ✅ $ev ($desc)"; else echo "  ❌ $ev ($desc) — NOT yet cleared"; fi
    done
    if artifact_msg="$(_file_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "  ✅ file_artifacts_verified (before file)"
    else
      echo "  ❌ file_artifacts_verified (before file) — $artifact_msg"
    fi
    if artifact_msg="$(_strategy_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "  ✅ strategy_artifacts_verified (before strategy)"
    else
      echo "  ❌ strategy_artifacts_verified (before strategy) — $artifact_msg"
    fi
    if artifact_msg="$(_retro_artifacts_valid "$MATTERS/$slug" 2>&1)"; then
      echo "  ✅ docket_artifacts_verified (before matter-retro)"
    else
      echo "  ❌ docket_artifacts_verified (before matter-retro) — $artifact_msg"
    fi ;;
  *) echo "usage: glaw-gate check <stage> [slug] | status [slug]"; exit 2 ;;
esac
