#!/usr/bin/env bash
# glaw-gate — code-ENFORCEMENT of the firm's hard gates (was prose-only in SKILL.md).
# A stage transition is BLOCKED unless the gate events required to enter it are present
# in the matter's timeline.jsonl. Fail-closed: if the required event is absent, exit 1.
#
# GATES (mirror CLAUDE.md "Hard gates"):
#   enter strategy  ⇐ intake_complete              (structured intake before work)
#                   ⇐ conflicts_cleared            (gate 1: conflicts before strategy)
#   enter file      ⇐ citations_verified           (gate 2: cites verified before file)
#                   ⇐ adversarial_done             (gate 3: RED→BLUE before file)
#                   ⇐ red_flags_clear              (no critical/high open findings)
#                   ⇐ final_packet_ready           (required council + manifest)
#                   ⇐ chief_approved               (Chief/Council final approval)
#   enter matter-retro ⇐ docket_gate_complete      (deadline review before close-out)
#                      ⇐ docket_done
# For guarded stages, event presence is necessary but not sufficient; the backing ledgers must
# prove the gate state.
#
# Usage:
#   glaw-gate check <target-stage> [slug]   # exit 0 = clear, 1 = blocked
#   glaw-gate status [slug]                 # show every gate's state for the matter
set -uo pipefail
GLAW_HOME="${GLAW_HOME:-$HOME/.glaw}"
MATTERS="$GLAW_HOME/matters"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# stage -> space-separated required timeline events
_required_events() {
  case "$1" in
    strategy) echo "intake_complete conflicts_cleared" ;;
    file)     echo "citations_verified adversarial_done red_flags_clear final_packet_ready chief_approved" ;;
    matter-retro) echo "docket_gate_complete docket_done" ;;
    *)        echo "" ;;   # unguarded transition
  esac
}

_has_event() {  # _has_event <timeline-file> <event>
  [ -f "$1" ] && grep -Eq "\"event\"[[:space:]]*:[[:space:]]*\"$2\"" "$1"
}

_strategy_artifacts_valid() {  # _strategy_artifacts_valid <matter-dir> <repo-root>
  python3 - "$1" "$2" <<'PY'
import json
import pathlib
import re
import sys

d = pathlib.Path(sys.argv[1])
root = pathlib.Path(sys.argv[2])
sys.path.insert(0, str(root / "lib"))
from glaw_profiles import TRACKS
SOURCE_ID_RE = re.compile(r"\bSRC-\d{4}\b")

REQUIRED_INTAKE = (
    "matter_name",
    "workflow_track",
    "client_names",
    "parties",
    "jurisdiction",
    "goal",
    "source_documents",
    "deadlines",
    "facts_timeline",
    "open_questions",
    "conflicts_parties",
    "authorized_scope",
)


def intake_missing_fields(intake):
    universal = intake.get("universal", {})
    missing = []
    if intake.get("status") != "complete":
        missing.append("status=complete")
    for key in REQUIRED_INTAKE:
        val = universal.get(key)
        if val in ("", None, [], {}):
            missing.append(f"universal.{key}")
    track = universal.get("workflow_track") or intake.get("workflow_track")
    if track not in TRACKS:
        missing.append("universal.workflow_track(valid)")
    for key in TRACKS.get(track, ()):
        val = intake.get("track_specific", {}).get(key)
        if val in ("", None, [], {}):
            missing.append(f"track_specific.{key}")
    return missing


def source_evidence_manifest():
    paths = []
    for part in ("evidence", "source_documents", "sources"):
        base = d / part
        if not base.exists():
            continue
        paths.extend(path for path in base.rglob("*") if path.is_file() and path.stat().st_size > 0)
    return [
        {"id": f"SRC-{idx:04d}", "path": str(path.relative_to(d))}
        for idx, path in enumerate(sorted(paths), start=1)
    ]


def validate_current_source(text, label, source_ids):
    text = str(text or "")
    refs = sorted(set(SOURCE_ID_RE.findall(text)))
    if not refs:
        print(f"{label} lacks source evidence id (SRC-####)")
        sys.exit(1)
    stale = [ref for ref in refs if ref not in source_ids]
    if stale:
        print(f"{label} cites non-current source evidence id(s): {', '.join(stale)}")
        sys.exit(1)


source_ids = {item["id"] for item in source_evidence_manifest()}
if not source_ids:
    print("no current nonempty source evidence file")
    sys.exit(1)


intake_path = d / "intake.json"
ethics_path = d / "ethics.json"
try:
    intake = json.loads(intake_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    print("intake.json missing")
    sys.exit(1)
except json.JSONDecodeError:
    print("intake.json is invalid JSON")
    sys.exit(1)
missing_intake = intake_missing_fields(intake)
if missing_intake:
    print("intake.json incomplete: " + ", ".join(missing_intake))
    sys.exit(1)
try:
    ethics = json.loads(ethics_path.read_text(encoding="utf-8"))
except FileNotFoundError:
    print("ethics.json missing")
    sys.exit(1)
except json.JSONDecodeError:
    print("ethics.json is invalid JSON")
    sys.exit(1)
if ethics.get("status") != "complete":
    print("ethics.json status is not complete")
    sys.exit(1)
if ethics.get("conflicts_status") not in {"cleared", "waived"}:
    print("ethics conflicts_status is not cleared or waived")
    sys.exit(1)
validate_current_source(ethics.get("conflicts_source", ""), "ethics conflicts_source", source_ids)
if ethics.get("conflicts_status") == "waived":
    validate_current_source(ethics.get("waiver_evidence", ""), "ethics waiver_evidence", source_ids)
engagement = ethics.get("engagement", {})
if engagement.get("status") != "drafted":
    print("ethics engagement is not drafted")
    sys.exit(1)
if not str(engagement.get("scope", "")).strip():
    print("ethics engagement scope is missing")
    sys.exit(1)
if not str(engagement.get("responsible_professional", "")).strip():
    print("ethics responsible professional is missing")
    sys.exit(1)
validate_current_source(engagement.get("source", ""), "ethics engagement source", source_ids)
PY
}

_file_artifacts_valid() {  # _file_artifacts_valid <matter-dir> <repo-root>
  python3 - "$1" "$2" <<'PY'
import hashlib
import json
import pathlib
import re
import sys
from urllib.parse import urlparse

d = pathlib.Path(sys.argv[1])
root = pathlib.Path(sys.argv[2])
sys.path.insert(0, str(root / "lib"))
from glaw_profiles import ADVERSARIAL_PROFILES, COUNCIL_PROFILES, REVIEWER_SKILL_MAP, TRACKS


def valid_http_url(value):
    parsed = urlparse(str(value).strip())
    return parsed.scheme in {"http", "https"} and bool(parsed.netloc)

REQUIRED_INTAKE = (
    "matter_name",
    "workflow_track",
    "client_names",
    "parties",
    "jurisdiction",
    "goal",
    "source_documents",
    "deadlines",
    "facts_timeline",
    "open_questions",
    "conflicts_parties",
    "authorized_scope",
)


def intake_missing_fields(intake):
    universal = intake.get("universal", {})
    missing = []
    if intake.get("status") != "complete":
        missing.append("status=complete")
    for key in REQUIRED_INTAKE:
        val = universal.get(key)
        if val in ("", None, [], {}):
            missing.append(f"universal.{key}")
    track = universal.get("workflow_track") or intake.get("workflow_track")
    if track not in TRACKS:
        missing.append("universal.workflow_track(valid)")
    for key in TRACKS.get(track, ()):
        val = intake.get("track_specific", {}).get(key)
        if val in ("", None, [], {}):
            missing.append(f"track_specific.{key}")
    return missing


def read_jsonl(path):
    rows = []
    if not path.exists():
        return rows
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            rows.append(json.loads(line))
        except json.JSONDecodeError:
            print(f"{path.name} contains invalid JSON")
            sys.exit(1)
    return rows


def latest_by(rows, key):
    latest = {}
    for row in rows:
        latest[str(row.get(key, ""))] = row
    return latest


def skill_name(path):
    in_frontmatter = False
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.strip() == "---":
            if not in_frontmatter:
                in_frontmatter = True
                continue
            break
        if in_frontmatter and line.startswith("name:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""


def skill_path_for(command):
    matches = []
    for path in root.rglob("SKILL.md"):
        if ".git" in path.parts:
            continue
        if skill_name(path) == command:
            matches.append(path)
    if not matches:
        return None
    return sorted(matches, key=lambda p: ("seats" in p.relative_to(root).parts, str(p.relative_to(root))))[0]


TEXT_DELIVERABLE_EXTS = {".md", ".html", ".htm", ".txt"}
TEXT_DELIVERABLE_SKIP_NAMES = {
    "matter.md",
    "index.md",
    "final_packet.md",
}
TEXT_DELIVERABLE_SKIP_PARTS = {
    "_published",
    "_extracted",
    "decisions",
    "evidence",
    "source_documents",
    "sources",
    "workpapers",
}
SOURCE_EVIDENCE_PARTS = {
    "evidence",
    "source_documents",
    "sources",
}
SOURCE_ID_RE = re.compile(r"\bSRC-\d{4}\b")
ACCOUNTING_CONTROL_PROFILES = {"accounting", "tax"}
NEGATIVE_DECISION_RE = re.compile(r"\b(DENY|DENIED|REJECT|REJECTED|REFUSE|REFUSED|BLOCK|BLOCKED|DO NOT PROCEED|NOT READY|WITH[- ]?FIXES|FIXES REQUIRED|FIX REQUIRED)\b", re.I)
APPROVAL_DECISION_RE = re.compile(r"\b(PROCEED|APPROVE|APPROVED|READY|FILE-READY)\b", re.I)
REQUIRED_GATE_ARTIFACTS = (
    "intake.json",
    "ethics.json",
    "citations.jsonl",
    "council.jsonl",
    "adversarial.jsonl",
)
OPTIONAL_GATE_ARTIFACTS = (
    "red_flags.jsonl",
    "accounting_control.json",
)
REPORT_REQUIRED_MARKERS = (
    "Owner:",
    "Report voice:",
    "Findings:",
    "Evidence:",
    "Red flags:",
    "Sign-off conditions:",
)
UNRESOLVED_PLACEHOLDER_RE = re.compile(r"\[(?:[A-Z][A-Z0-9 _./:-]{1,}|VERIFY|TODO|TBD)[^\]]*\]")
UNRESOLVED_REVIEW_RE = re.compile(r"\bREVIEW\s*:", re.IGNORECASE)


def is_external_text_deliverable(path):
    if path.suffix.lower() not in TEXT_DELIVERABLE_EXTS:
        return False
    if path.name in TEXT_DELIVERABLE_SKIP_NAMES:
        return False
    return not bool(set(path.relative_to(d).parts) & TEXT_DELIVERABLE_SKIP_PARTS)


def is_source_evidence(path):
    if not path.is_file():
        return False
    return bool(set(path.relative_to(d).parts) & SOURCE_EVIDENCE_PARTS)


def has_upl_footer(text):
    lower = text.lower()
    work_product = "attorney work-product" in lower or "work-product" in lower
    no_advice = "not legal advice" in lower or "not legal, tax, or accounting advice" in lower
    return work_product and no_advice


def sha256_file(path):
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def sha256_text(text):
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def source_evidence_manifest(paths):
    return [
        {
            "id": f"SRC-{idx:04d}",
            "path": str(path.relative_to(d)),
            "sha256": sha256_file(path),
            "size_bytes": path.stat().st_size,
        }
        for idx, path in enumerate(sorted(paths), start=1)
    ]


def reviewer_identity_manifest(profile):
    required = [("council", name) for name in COUNCIL_PROFILES.get(profile, ())]
    required.extend(("adversarial", name) for name in ADVERSARIAL_PROFILES.get(profile, ()))
    rows = []
    for kind, name in required:
        command = REVIEWER_SKILL_MAP.get(name, "")
        missing = []
        path = skill_path_for(command) if command else None
        text = path.read_text(encoding="utf-8", errors="replace") if path else ""
        if not command:
            missing.append("reviewer skill mapping")
        if not path:
            missing.append("skill file")
        if "Identity:" not in text:
            missing.append("Identity:")
        if "Soul:" not in text:
            missing.append("Soul:")
        if "Report voice:" not in text:
            missing.append("Report voice:")
        rows.append({
            "kind": kind,
            "name": name,
            "skill": command,
            "path": str(path.relative_to(root)) if path else "",
            "sha256": sha256_file(path) if path else "",
            "status": "pass" if not missing else "fail",
            "missing": missing,
        })
    return rows


def report_quality(path, source_manifest):
    text = path.read_text(encoding="utf-8", errors="replace")
    missing = [marker for marker in REPORT_REQUIRED_MARKERS if marker.lower() not in text.lower()]
    placeholders = sorted(set(UNRESOLVED_PLACEHOLDER_RE.findall(text)))
    review_markers = sorted(set(UNRESOLVED_REVIEW_RE.findall(text)))
    source_ids = [item["id"] for item in source_manifest]
    cited_sources = [sid for sid in source_ids if sid in text]
    referenced_sources = sorted(set(SOURCE_ID_RE.findall(text)))
    stale_sources = sorted(set(referenced_sources) - set(source_ids))
    if not source_ids:
        missing.append("source evidence manifest")
    elif not cited_sources:
        missing.append("source evidence id (SRC-####)")
    elif stale_sources:
        missing.append("non-current source evidence id")
    if placeholders:
        missing.append("unresolved placeholders")
    if review_markers:
        missing.append("unresolved REVIEW markers")
    return {
        "path": str(path.relative_to(d)),
        "status": "pass" if not missing else "fail",
        "missing_markers": missing,
        "cited_source_ids": cited_sources,
        "unresolved_placeholders": placeholders,
        "unresolved_review_markers": review_markers,
    }


def review_evidence_manifest(council_rows, adversarial_rows, profile, source_manifest):
    source_ids = [item["id"] for item in source_manifest]
    rows = []
    latest_council = latest_by(council_rows, "role")
    for role in COUNCIL_PROFILES.get(profile, ()):
        row = latest_council.get(role, {})
        evidence = str(row.get("evidence", ""))
        notes = str(row.get("notes", ""))
        cited = [sid for sid in source_ids if sid in evidence]
        referenced = sorted(set(SOURCE_ID_RE.findall(evidence)))
        stale = sorted(set(referenced) - set(source_ids))
        missing = []
        if not row:
            missing.append("review row")
        if not evidence.strip():
            missing.append("evidence")
        if not cited:
            missing.append("source evidence id (SRC-####)")
        elif stale:
            missing.append("non-current source evidence id")
        if not notes.strip():
            missing.append("notes/conclusion")
        rows.append({
            "kind": "council",
            "name": role,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "cited_source_ids": cited,
        })
    latest_adversarial = latest_by(adversarial_rows, "lens")
    for lens in ADVERSARIAL_PROFILES.get(profile, ()):
        row = latest_adversarial.get(lens, {})
        evidence = str(row.get("evidence", ""))
        attack = str(row.get("attack", ""))
        cited = [sid for sid in source_ids if sid in evidence]
        attack_cited = [sid for sid in source_ids if sid in attack]
        referenced = sorted(set(SOURCE_ID_RE.findall(evidence)))
        attack_referenced = sorted(set(SOURCE_ID_RE.findall(attack)))
        stale = sorted(set(referenced) - set(source_ids))
        attack_stale = sorted(set(attack_referenced) - set(source_ids))
        missing = []
        if not row:
            missing.append("review row")
        if not evidence.strip():
            missing.append("evidence")
        if not cited:
            missing.append("source evidence id (SRC-####)")
        elif stale:
            missing.append("non-current source evidence id")
        if not attack.strip():
            missing.append("attack/challenge")
        if not attack_cited:
            missing.append("attack source evidence id (SRC-####)")
        elif attack_stale:
            missing.append("non-current attack source evidence id")
        rows.append({
            "kind": "adversarial",
            "name": lens,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "cited_source_ids": cited,
            "attack_cited_source_ids": attack_cited,
        })
    return rows


def red_flag_resolution_manifest(red_flags, source_manifest):
    source_ids = [item["id"] for item in source_manifest]
    rows = []
    for flag in red_flags:
        severity = str(flag.get("severity", "")).lower()
        if severity not in {"critical", "high"}:
            continue
        if flag.get("status", "open") != "resolved":
            continue
        evidence = str(flag.get("resolution_evidence", ""))
        cited = [sid for sid in source_ids if sid in evidence]
        syntactic = sorted(set(SOURCE_ID_RE.findall(evidence)))
        missing = []
        if not evidence.strip():
            missing.append("resolution evidence")
        if not syntactic:
            missing.append("source evidence id (SRC-####)")
        elif not cited:
            missing.append("current source evidence id")
        elif sorted(set(syntactic) - set(source_ids)):
            missing.append("non-current source evidence id")
        rows.append({
            "id": flag.get("id", ""),
            "severity": severity,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "cited_source_ids": cited,
            "referenced_source_ids": syntactic,
        })
    return rows


def nonblocking_red_flag_manifest(red_flags, source_manifest):
    source_ids = [item["id"] for item in source_manifest]
    rows = []
    for flag in red_flags:
        severity = str(flag.get("severity", "")).lower()
        if severity in {"critical", "high"}:
            continue
        if flag.get("status", "open") == "resolved":
            continue
        source = str(flag.get("source", ""))
        cited = [sid for sid in source_ids if sid in source]
        syntactic = sorted(set(SOURCE_ID_RE.findall(source)))
        missing = []
        if not severity:
            missing.append("severity")
        if not str(flag.get("finding", "")).strip():
            missing.append("finding")
        if not str(flag.get("owner", "")).strip():
            missing.append("owner")
        if not str(flag.get("required_fix", "")).strip():
            missing.append("required_fix")
        if not source.strip():
            missing.append("source")
        if not syntactic:
            missing.append("source evidence id (SRC-####)")
        elif not cited:
            missing.append("current source evidence id")
        elif sorted(set(syntactic) - set(source_ids)):
            missing.append("non-current source evidence id")
        rows.append({
            "id": flag.get("id", ""),
            "severity": severity,
            "status": "pass" if not missing else "fail",
            "missing": missing,
            "owner": flag.get("owner", ""),
            "required_fix": flag.get("required_fix", ""),
            "finding": flag.get("finding", ""),
            "cited_source_ids": cited,
            "referenced_source_ids": syntactic,
        })
    return rows


def _boolish(value):
    if isinstance(value, bool):
        return value
    return str(value).strip().lower() in {"1", "true", "yes", "pass", "passed", "ok"}


def _zeroish(value):
    try:
        return float(str(value).strip()) == 0.0
    except ValueError:
        return False


def _int_value(value):
    try:
        return int(value)
    except (TypeError, ValueError):
        return -1


def _artifact_hash(path_text, label, missing):
    if not str(path_text).strip():
        missing.append(f"{label}.artifact")
        return {"label": label, "path": str(path_text), "sha256": "", "size_bytes": 0}
    path = (d / str(path_text)).resolve()
    try:
        rel_path = str(path.relative_to(d.resolve()))
    except ValueError:
        missing.append(f"{label}.artifact inside matter")
        return {"label": label, "path": str(path_text), "sha256": "", "size_bytes": 0}
    if not path.is_file():
        missing.append(f"{label}.artifact exists")
        return {"label": label, "path": rel_path, "sha256": "", "size_bytes": 0}
    size = path.stat().st_size
    if size <= 0:
        missing.append(f"{label}.artifact nonempty")
    return {"label": label, "path": rel_path, "sha256": sha256_file(path), "size_bytes": size}


def accounting_control_manifest(profile, source_manifest):
    required = profile in ACCOUNTING_CONTROL_PROFILES
    path = d / "accounting_control.json"
    source_ids = [item["id"] for item in source_manifest]
    manifest = {
        "required": required,
        "path": "accounting_control.json",
        "status": "pass",
        "missing": [],
        "sha256": "",
        "artifact_hashes": [],
    }
    if not required:
        manifest["status"] = "not_required"
        return manifest
    if not path.exists():
        manifest["status"] = "fail"
        manifest["missing"].append("accounting_control.json")
        return manifest
    manifest["sha256"] = sha256_file(path)
    try:
        control = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        manifest["status"] = "fail"
        manifest["missing"].append("valid JSON")
        return manifest

    if control.get("status") != "pass":
        manifest["missing"].append("status=pass")
    source_text = str(control.get("source", ""))
    cited = [sid for sid in source_ids if sid in source_text]
    syntactic = sorted(set(SOURCE_ID_RE.findall(source_text)))
    if not SOURCE_ID_RE.search(source_text):
        manifest["missing"].append("source evidence id (SRC-####)")
    elif not cited:
        manifest["missing"].append("current source evidence id")
    elif sorted(set(syntactic) - set(source_ids)):
        manifest["missing"].append("non-current source evidence id")

    ledger = control.get("ledger", {})
    if ledger.get("status") != "pass":
        manifest["missing"].append("ledger.status=pass")
    manifest["artifact_hashes"].append(
        _artifact_hash(ledger.get("artifact", ""), "ledger", manifest["missing"])
    )

    books = control.get("books_doctor", {})
    if books.get("status") != "pass":
        manifest["missing"].append("books_doctor.status=pass")
    if not _boolish(books.get("require_rec")):
        manifest["missing"].append("books_doctor.require_rec=true")
    manifest["artifact_hashes"].append(
        _artifact_hash(books.get("artifact", ""), "books_doctor", manifest["missing"])
    )

    rec = control.get("bank_reconciliation", {})
    if rec.get("status") != "pass":
        manifest["missing"].append("bank_reconciliation.status=pass")
    if not _boolish(rec.get("reconciled")):
        manifest["missing"].append("bank_reconciliation.reconciled=true")
    if not _zeroish(rec.get("unreconciled_difference")):
        manifest["missing"].append("bank_reconciliation.unreconciled_difference=0")
    if _int_value(rec.get("book_only_count", 0)) != 0:
        manifest["missing"].append("bank_reconciliation.book_only_count=0")
    if _int_value(rec.get("bank_only_count", 0)) != 0:
        manifest["missing"].append("bank_reconciliation.bank_only_count=0")
    manifest["artifact_hashes"].append(
        _artifact_hash(rec.get("artifact", ""), "bank_reconciliation", manifest["missing"])
    )

    if profile == "tax":
        tax = control.get("tax_tieout", {})
        if tax.get("status") != "pass":
            manifest["missing"].append("tax_tieout.status=pass")
        if not _boolish(tax.get("provision_ties")):
            manifest["missing"].append("tax_tieout.provision_ties=true")
        if not _boolish(tax.get("internal_consistency")):
            manifest["missing"].append("tax_tieout.internal_consistency=true")
        manifest["artifact_hashes"].append(
            _artifact_hash(tax.get("artifact", ""), "tax_tieout", manifest["missing"])
        )

    if manifest["missing"]:
        manifest["status"] = "fail"
    return manifest


def decision_hash(row):
    payload = dict(row)
    payload.pop("decision_hash", None)
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def row_hash(row):
    payload = dict(row)
    payload.pop("row_hash", None)
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def validate_row_hashes(rows, ledger_name):
    failures = []
    for idx, row in enumerate(rows, start=1):
        expected = row.get("row_hash")
        if not expected:
            failures.append(f"{ledger_name}:{idx} missing row_hash")
        elif expected != row_hash(row):
            failures.append(f"{ledger_name}:{idx} row_hash mismatch")
    if failures:
        print("review ledger row hash failure: " + "; ".join(failures))
        sys.exit(1)


