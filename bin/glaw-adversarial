#!/usr/bin/env python3
"""GLAW adversarial RED-team ledger for government/regulatory attack lenses."""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))
from glaw_profiles import ADVERSARIAL_PROFILES as PROFILES
from glaw_profiles import profile_for_track


SOURCE_EVIDENCE_PARTS = {"evidence", "source_documents", "sources"}


def now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def slugify(text: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")


def home() -> Path:
    return Path(os.environ.get("GLAW_HOME", str(Path.home() / ".glaw")))


def active_slug() -> str:
    p = home() / ".active"
    return p.read_text(encoding="utf-8").strip() if p.exists() else ""


def matter_dir(slug: str | None) -> Path:
    s = slug or active_slug()
    if not s:
        raise SystemExit("ERROR: no active matter. Run `glaw matter new \"<name>\"` first.")
    d = home() / "matters" / s
    if not d.is_dir():
        raise SystemExit(f"ERROR: matter not found: {s}")
    return d


def append_jsonl(path: Path, row: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, sort_keys=False) + "\n")


def row_hash(row: dict) -> str:
    payload = dict(row)
    payload.pop("row_hash", None)
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def stamp_row_hash(row: dict) -> dict:
    row["row_hash"] = row_hash(row)
    return row


def validate_row_hashes(rows: list[dict], ledger_name: str) -> list[str]:
    failures = []
    for idx, row in enumerate(rows, start=1):
        expected = row.get("row_hash")
        if not expected:
            failures.append(f"{ledger_name}:{idx} missing row_hash")
        elif expected != row_hash(row):
            failures.append(f"{ledger_name}:{idx} row_hash mismatch")
    return failures


def evidence_source_ids(evidence: str) -> list[str]:
    return sorted(set(re.findall(r"\bSRC-\d{4}\b", evidence)))


def is_source_evidence(path: Path, root: Path) -> bool:
    if not path.is_file():
        return False
    return bool(set(path.relative_to(root).parts) & SOURCE_EVIDENCE_PARTS)


def current_source_ids(d: Path) -> set[str]:
    paths = [p for p in d.rglob("*") if is_source_evidence(p, d) and p.stat().st_size > 0]
    return {f"SRC-{idx:04d}" for idx, _path in enumerate(sorted(paths), start=1)}


def noncurrent_source_ids(text: str, d: Path) -> list[str]:
    cited = set(evidence_source_ids(text))
    if not cited:
        return []
    current = current_source_ids(d)
    return sorted(cited - current)


def require_current_source_ids(text: str, d: Path, context: str) -> None:
    cited = evidence_source_ids(text)
    if not cited:
        return
    stale = noncurrent_source_ids(text, d)
    if stale:
        raise SystemExit(
            f"ERROR: {context} must cite current source artifact ID(s); "
            f"non-current: {', '.join(stale)}"
        )


def read_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    rows = []
    for idx, line in enumerate(path.read_text(encoding="utf-8", errors="replace").splitlines(), start=1):
        if not line.strip():
            continue
        try:
            rows.append(json.loads(line))
        except json.JSONDecodeError as exc:
            raise SystemExit(f"ERROR: {path.name}:{idx} invalid JSON: {exc.msg}") from exc
    return rows


def timeline(d: Path, event: str, **extra: object) -> None:
    append_jsonl(d / "timeline.jsonl", {"ts": now(), "event": event, **extra})


def intake_profile(d: Path) -> str:
    p = d / "intake.json"
    if not p.exists():
        return "hybrid"
    try:
        form = json.loads(p.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return "hybrid"
    track = form.get("universal", {}).get("workflow_track") or form.get("workflow_track")
    return profile_for_track(track)


def profile_for(args: argparse.Namespace, d: Path) -> str:
    return args.profile if args.profile != "auto" else intake_profile(d)


def latest_by_lens(rows: list[dict]) -> dict[str, dict]:
    latest: dict[str, dict] = {}
    for row in rows:
        latest[row.get("lens", "")] = row
    return latest


def open_red_flag(d: Path, *, profile: str, lens: str, row: dict) -> None:
    existing = read_jsonl(d / "red_flags.jsonl")
    rid = f"RF-{len(existing) + 1:04d}"
    severity = "critical" if row["decision"] == "strike" else "high"
    origin = f"adversarial:{profile}:{lens}"
    flag = {
        "ts": now(),
        "id": rid,
        "severity": severity,
        "owner": lens,
        "source": " ".join(evidence_source_ids(row["attack"])),
        "origin": origin,
        "finding": row["attack"] or f"{lens} returned {row['decision']}",
        "required_fix": row["cure"] or "Rebuild or drop the attacked position and re-run RED review.",
        "status": "open",
        "resolution_evidence": "",
    }
    append_jsonl(d / "red_flags.jsonl", flag)
    timeline(d, "red_flag_opened", id=rid, severity=severity, owner=lens, source=flag["source"], origin=origin)


def cmd_record(args: argparse.Namespace) -> int:
    d = matter_dir(args.matter)
    profile = profile_for(args, d)
    lens = slugify(args.lens)
    if args.decision == "survive":
        if not args.attack.strip():
            raise SystemExit("ERROR: adversarial survive requires --attack with the challenge tested.")
        if not evidence_source_ids(args.attack):
            raise SystemExit("ERROR: adversarial survive attack must cite a source artifact ID such as SRC-0001.")
        require_current_source_ids(args.attack, d, "adversarial survive attack")
        if not args.evidence.strip():
            raise SystemExit("ERROR: adversarial survive requires --evidence with the source-backed proof reviewed.")
        if not evidence_source_ids(args.evidence):
            raise SystemExit("ERROR: adversarial survive evidence must cite a source artifact ID such as SRC-0001.")
        require_current_source_ids(args.evidence, d, "adversarial survive evidence")
    if args.decision == "fix" and (not args.attack.strip() or not args.cure.strip()):
        raise SystemExit("ERROR: adversarial fix requires both --attack and --cure.")
    if args.decision == "strike" and not args.attack.strip():
        raise SystemExit("ERROR: adversarial strike requires --attack.")
    if args.decision in {"fix", "strike"} and not evidence_source_ids(args.attack):
        raise SystemExit("ERROR: adversarial fix/strike attack must cite a source artifact ID such as SRC-0001.")
    if args.decision in {"fix", "strike"}:
        require_current_source_ids(args.attack, d, "adversarial fix/strike attack")
    row = {
        "ts": now(),
        "profile": profile,
        "lens": lens,
        "display_lens": args.lens,
        "position": args.position,
        "decision": args.decision,
        "attack": args.attack,
        "cure": args.cure,
        "evidence": args.evidence,
    }
    append_jsonl(d / "adversarial.jsonl", stamp_row_hash(row))
    timeline(d, "adversarial_review", profile=profile, lens=lens, decision=args.decision)
    if args.decision == "survive":
        timeline(d, f"adversarial_survived_{lens}", profile=profile)
    else:
        open_red_flag(d, profile=profile, lens=lens, row=row)
    print(f"RECORDED {profile} adversarial review: {lens}={args.decision}")
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    d = matter_dir(args.matter)
    profile = profile_for(args, d)
    required = PROFILES[profile]
    rows = read_jsonl(d / "adversarial.jsonl")
    hash_failures = validate_row_hashes(rows, "adversarial.jsonl")
    if hash_failures:
        print("ADVERSARIAL BLOCKED: ledger row hash failure")
        for failure in hash_failures:
            print(f"  {failure}")
        return 1
    latest = latest_by_lens([r for r in rows if r.get("profile") == profile])
    failures = []
    current_sources = current_source_ids(d)
    print(f"ADVERSARIAL {profile} - {d.name}")
    for lens in required:
        row = latest.get(lens)
        if not row:
            print(f"  MISSING {lens}")
            failures.append(lens)
            continue
        decision = row.get("decision")
        evidence = str(row.get("evidence", ""))
        attack = str(row.get("attack", ""))
        evidence_gap = decision == "survive" and not evidence.strip()
        source_id_gap = decision == "survive" and not evidence_source_ids(evidence)
        noncurrent_source_gap = decision == "survive" and bool(noncurrent_source_ids(evidence, d))
        no_source_artifacts_gap = decision == "survive" and bool(evidence_source_ids(evidence)) and not current_sources
        attack_gap = decision == "survive" and not attack.strip()
        attack_source_id_gap = decision == "survive" and not evidence_source_ids(attack)
        attack_noncurrent_source_gap = decision == "survive" and bool(noncurrent_source_ids(attack, d))
        icon = "OK" if (
            decision == "survive"
            and not evidence_gap
            and not source_id_gap
            and not noncurrent_source_gap
            and not no_source_artifacts_gap
            and not attack_gap
            and not attack_source_id_gap
            and not attack_noncurrent_source_gap
        ) else "BLOCK"
        print(f"  {icon} {lens}: {decision}")
        if row.get("attack"):
            print(f"      attack: {row['attack']}")
        if row.get("cure"):
            print(f"      cure: {row['cure']}")
        if evidence_gap:
            print("      evidence: MISSING")
        if source_id_gap:
            print("      source evidence id: MISSING")
        if no_source_artifacts_gap:
            print("      current source artifact: MISSING")
        if noncurrent_source_gap:
            print(f"      non-current evidence source id: {', '.join(noncurrent_source_ids(evidence, d))}")
        if attack_gap:
            print("      attack/challenge: MISSING")
        if attack_source_id_gap:
            print("      attack source evidence id: MISSING")
        if attack_noncurrent_source_gap:
            print(f"      non-current attack source id: {', '.join(noncurrent_source_ids(attack, d))}")
        if (
            decision != "survive"
            or evidence_gap
            or source_id_gap
            or noncurrent_source_gap
            or no_source_artifacts_gap
            or attack_gap
            or attack_source_id_gap
            or attack_noncurrent_source_gap
        ):
            failures.append(lens)
    if failures:
        print("ADVERSARIAL BLOCKED")
        return 1
    print("ADVERSARIAL READY")
    return 0


def cmd_complete(args: argparse.Namespace) -> int:
    d = matter_dir(args.matter)
    args.profile = profile_for(args, d)
    rc = cmd_status(args)
    if rc != 0:
        return rc
    timeline(d, f"{args.profile}_adversarial_complete", profile=args.profile)
    timeline(d, "adversarial_done", profile=args.profile)
    print(f"{args.profile.upper()} ADVERSARIAL COMPLETE")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="glaw-adversarial")
    sub = ap.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("record", help="record one RED-team lens review")
    p.add_argument("--profile", default="auto", choices=["auto", *sorted(PROFILES)])
    p.add_argument("--lens", required=True, help="e.g. irs-examiner, sec-reviewer, opposing-counsel")
    p.add_argument("--decision", required=True, choices=["survive", "fix", "strike"])
    p.add_argument("--position", default="matter work-product")
    p.add_argument("--attack", default="")
    p.add_argument("--cure", default="")
    p.add_argument("--evidence", default="")
    p.add_argument("--matter", default=None)
    p.set_defaults(func=cmd_record)
    p = sub.add_parser("status", help="show required RED-team lens completion")
    p.add_argument("--profile", default="auto", choices=["auto", *sorted(PROFILES)])
    p.add_argument("--matter", default=None)
    p.set_defaults(func=cmd_status)
    p = sub.add_parser("complete", help="log adversarial_done only when every lens survives")
    p.add_argument("--profile", default="auto", choices=["auto", *sorted(PROFILES)])
    p.add_argument("--matter", default=None)
    p.set_defaults(func=cmd_complete)
    args = ap.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
