#!/usr/bin/env python3
"""glaw-daemon - standing-goal and docket watcher.

Usage:
  glaw-daemon status [--json]
  glaw-daemon goal add --name NAME --objective TEXT [--kind docket-watch|matter-loop] [--horizon-days N]
  glaw-daemon goal list [--json]
  glaw-daemon goal disable --name NAME
  glaw-daemon once [--json] [--horizon-days N]

This is a source-only daemon primitive: it performs one deterministic scan and
exits. A scheduler/host may call it repeatedly. It does not file, sign, serve,
pay, charge, transmit, or advance a matter stage.
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import date, datetime, timedelta, timezone
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "lib"))
from glaw_oversight import status as oversight_status


def now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def home() -> Path:
    return Path(os.environ.get("GLAW_HOME", str(Path.home() / ".glaw")))


def matters_dir() -> Path:
    return home() / "matters"


def daemon_dir() -> Path:
    path = home() / "daemon"
    path.mkdir(parents=True, exist_ok=True)
    return path


def goals_path() -> Path:
    return home() / "goals.jsonl"


def run_ledger_path() -> Path:
    return daemon_dir() / "runs.jsonl"


def append_jsonl(path: Path, row: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, sort_keys=False) + "\n")


def read_jsonl(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    rows: list[dict[str, Any]] = []
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            value = json.loads(line)
            if isinstance(value, dict):
                rows.append(value)
        except json.JSONDecodeError:
            rows.append({"event": "invalid_jsonl", "raw": line[:160]})
    return rows


def active_goals() -> list[dict[str, Any]]:
    goals: dict[str, dict[str, Any]] = {}
    for row in read_jsonl(goals_path()):
        name = str(row.get("name", "")).strip()
        if not name:
            continue
        goals[name] = row
    return [row for row in goals.values() if row.get("status", "active") == "active"]


def add_goal(args: argparse.Namespace) -> dict[str, Any]:
    row = {
        "ts": now(),
        "event": "goal_added",
        "name": args.name.strip(),
        "objective": args.objective.strip(),
        "kind": args.kind,
        "horizon_days": max(0, int(args.horizon_days)),
        "status": "active",
    }
    if not row["name"]:
        raise ValueError("--name is required")
    if not row["objective"]:
        raise ValueError("--objective is required")
    append_jsonl(goals_path(), row)
    return row


def disable_goal(args: argparse.Namespace) -> dict[str, Any]:
    row = {
        "ts": now(),
        "event": "goal_disabled",
        "name": args.name.strip(),
        "status": "disabled",
    }
    if not row["name"]:
        raise ValueError("--name is required")
    append_jsonl(goals_path(), row)
    return row


def matter_dirs() -> list[Path]:
    base = matters_dir()
    if not base.exists():
        return []
    return sorted([p for p in base.iterdir() if p.is_dir()])


def read_docket(path: Path) -> list[dict[str, Any]]:
    rows = []
    for idx, row in enumerate(read_jsonl(path / "docket.jsonl"), start=1):
        row = dict(row)
        row["_row"] = idx
        rows.append(row)
    return rows


def days_until(due: str, today: date) -> int | None:
    try:
        return (date.fromisoformat(due) - today).days
    except (TypeError, ValueError):
        return None


def loop_status(slug: str) -> dict[str, Any]:
    proc = subprocess.run(
        [str(ROOT / "bin" / "glaw-loop"), "status", "--matter", slug, "--json"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
        env=os.environ.copy(),
    )
    try:
        data = json.loads(proc.stdout)
        if isinstance(data, dict):
            data.setdefault("exit_code", proc.returncode)
            return data
    except json.JSONDecodeError:
        pass
    return {
        "matter": slug,
        "exit_code": proc.returncode,
        "quality_state": "blocked",
        "owner": "orchestrator",
        "next_command": "bin/glaw-loop status",
        "reason": proc.stdout.strip() or "loop status unavailable",
    }


def scan_deadlines(horizon_days: int) -> list[dict[str, Any]]:
    today = date.today()
    cutoff = today + timedelta(days=max(0, horizon_days))
    actions: list[dict[str, Any]] = []
    for matter in matter_dirs():
        for row in read_docket(matter):
            if str(row.get("status", "open")).lower() not in {"", "open"}:
                continue
            due = str(row.get("due", ""))
            delta = days_until(due, today)
            if delta is None:
                actions.append({
                    "kind": "invalid_docket",
                    "matter": matter.name,
                    "row": row.get("_row"),
                    "severity": "high",
                    "owner": row.get("owner") or "docket",
                    "reason": "docket row has invalid due date",
                    "next_command": "bin/glaw docket list",
                })
                continue
            if delta < 0:
                severity = "critical"
            elif date.fromisoformat(due) <= cutoff:
                severity = "high" if delta <= 7 else "medium"
            else:
                continue
            loop = loop_status(matter.name)
            actions.append({
                "kind": "deadline",
                "matter": matter.name,
                "due": due,
                "days_until_due": delta,
                "severity": severity,
                "desc": row.get("desc", ""),
                "owner": row.get("owner") or "docket",
                "source": row.get("source", ""),
                "next_command": "bin/glaw-loop once --matter " + matter.name,
                "loop_owner": loop.get("owner", ""),
                "loop_next_gate": loop.get("next_gate", ""),
                "loop_reason": loop.get("reason", ""),
            })
    return actions


def once(args: argparse.Namespace) -> tuple[int, dict[str, Any]]:
    oversight = oversight_status(5)
    if oversight.get("status") == "halted":
        report = {
            "ts": now(),
            "status": "halted",
            "reason": "oversight kill-switch active",
            "oversight": oversight,
            "actions": [],
            "authority": "daemon stopped; human Oversight Board review required",
        }
        append_jsonl(run_ledger_path(), report)
        return 1, report

    goals = active_goals()
    horizon = max([int(g.get("horizon_days", 0) or 0) for g in goals if g.get("kind", "docket-watch") == "docket-watch"] + [int(args.horizon_days)])
    actions = scan_deadlines(horizon)
    report = {
        "ts": now(),
        "status": "attention_required" if actions else "clear",
        "goals": goals,
        "horizon_days": horizon,
        "matters_scanned": len(matter_dirs()),
        "actions": actions,
        "authority": "scan and route only; no filing/signing/service/payment/charge/live transmission",
    }
    append_jsonl(run_ledger_path(), report)
    return (1 if actions else 0), report


def status_report() -> dict[str, Any]:
    goals = active_goals()
    return {
        "status": "active" if oversight_status(1).get("status") != "halted" else "halted",
        "goals": goals,
        "matter_count": len(matter_dirs()),
        "goals_path": str(goals_path()),
        "run_ledger": str(run_ledger_path()),
    }


def emit(data: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(data, indent=2, sort_keys=False))
    else:
        print(f"GLAW DAEMON: {data.get('status')}")
        if "matter_count" in data:
            print(f"  matters: {data.get('matter_count')}")
        if "horizon_days" in data:
            print(f"  horizon_days: {data.get('horizon_days')}")
        for item in data.get("actions", []):
            print(f"  {item.get('severity')}: {item.get('matter')} {item.get('due', '')} {item.get('desc', item.get('reason', ''))}")


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(prog="glaw-daemon")
    sub = ap.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("status")
    p.add_argument("--json", action="store_true")
    g = sub.add_parser("goal")
    gsub = g.add_subparsers(dest="goal_cmd", required=True)
    ga = gsub.add_parser("add")
    ga.add_argument("--name", required=True)
    ga.add_argument("--objective", required=True)
    ga.add_argument("--kind", choices=("docket-watch", "matter-loop"), default="docket-watch")
    ga.add_argument("--horizon-days", type=int, default=30)
    gl = gsub.add_parser("list")
    gl.add_argument("--json", action="store_true")
    gd = gsub.add_parser("disable")
    gd.add_argument("--name", required=True)
    o = sub.add_parser("once")
    o.add_argument("--json", action="store_true")
    o.add_argument("--horizon-days", type=int, default=30)
    args = ap.parse_args(argv)

    try:
        if args.cmd == "status":
            emit(status_report(), args.json)
            return 0
        if args.cmd == "goal" and args.goal_cmd == "add":
            row = add_goal(args)
            print(json.dumps(row, indent=2, sort_keys=False))
            return 0
        if args.cmd == "goal" and args.goal_cmd == "disable":
            row = disable_goal(args)
            print(json.dumps(row, indent=2, sort_keys=False))
            return 0
        if args.cmd == "goal" and args.goal_cmd == "list":
            data = {"status": "active", "goals": active_goals()}
            emit(data, args.json)
            return 0
        if args.cmd == "once":
            rc, report = once(args)
            emit(report, args.json)
            return rc
    except Exception as exc:
        data = {"status": "blocked", "reason": str(exc)}
        emit(data, getattr(args, "json", False))
        return 2
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
