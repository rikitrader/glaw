#!/usr/bin/env python3
"""glaw-loop - fail-closed orchestrator loop for matter routing.

Usage:
  glaw-loop status [--matter <slug>] [--json] [--max-iterations N]
  glaw-loop once [--matter <slug>] [--json] [--max-iterations N] [--acceptance TEXT] [--request-action <file|serve|sign|transmit|charge|pay|submit-live>] [--role ADMIN]

The loop reports the next gate/department that owns the matter. It may prepare
work, but it never files, serves, signs, transmits, pays, or charges.
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "lib"))
from glaw_authority import HUMAN_ONLY_ACTIONS, require_human_authority
from glaw_compliance import compliance_action_plan, compliance_failures
from glaw_oversight import escalate as oversight_escalate
from glaw_oversight import status as oversight_status
from glaw_profiles import ADVERSARIAL_PROFILES, COUNCIL_PROFILES, profile_for_track


def now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def home() -> Path:
    return Path(os.environ.get("GLAW_HOME", str(Path.home() / ".glaw")))


def active_slug() -> str:
    p = home() / ".active"
    return p.read_text(encoding="utf-8").strip() if p.exists() else ""


def matter_dir(slug: str | None) -> Path:
    s = slug or active_slug()
    if not s:
        raise SystemExit("ERROR: no active matter. Run `glaw matter new \"<name>\"` first.")
    d = home() / "matters" / s
    if not d.is_dir():
        raise SystemExit(f"ERROR: matter not found: {s}")
    return d


def read_json(path: Path, default):
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return default


def read_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    rows = []
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.strip():
            try:
                rows.append(json.loads(line))
            except json.JSONDecodeError:
                rows.append({"event": "invalid_jsonl"})
    return rows


def has_event(rows: list[dict], event: str) -> bool:
    return any(row.get("event") == event for row in rows)


def append_jsonl(path: Path, row: dict) -> None:
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, sort_keys=False) + "\n")


def run_tool(*args: str) -> tuple[int, str]:
    proc = subprocess.run(
        [str(ROOT / "bin" / args[0]), *args[1:]],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    return proc.returncode, proc.stdout.strip()


def gate_check(stage: str, slug: str) -> tuple[bool, str]:
    rc, output = run_tool("glaw-gate", "check", stage, slug)
    return rc == 0, output


def matter_profile(d: Path) -> tuple[str, str]:
    intake = read_json(d / "intake.json", {})
    track = intake.get("universal", {}).get("workflow_track") or intake.get("workflow_track") or "unset"
    return str(track), profile_for_track(track)


def final_packet_compliance_failures(d: Path) -> list[dict]:
    packet = read_json(d / "final_packet.json", {})
    return compliance_failures(packet.get("compliance_manifest"))


def final_packet_compliance_action_plan(d: Path) -> list[dict]:
    packet = read_json(d / "final_packet.json", {})
    return compliance_action_plan(packet.get("compliance_manifest"))


def compliance_failure_summary(failures: list[dict]) -> str:
    labels = []
    for row in failures[:5]:
        label = str(row.get("id") or row.get("owner") or "unnamed").strip()
        if label:
            labels.append(label)
    suffix = "" if len(failures) <= 5 else f" and {len(failures) - 5} more"
    return ", ".join(labels) + suffix


def compliance_failure_route(failures: list[dict]) -> tuple[str, str, str]:
    row_ids = {str(row.get("id") or "").strip().lower() for row in failures}
    owners = {str(row.get("owner") or "").strip().lower() for row in failures}
    summary = compliance_failure_summary(failures)
    if "accounting-control" in row_ids or "glaw-accounting" in owners:
        return (
            "accounting-control",
            "bin/glaw-accounting-control",
            "final packet accounting controls are blocked: " + summary,
        )
    if "government-adversary" in row_ids or "glaw-adversarial" in owners:
        return (
            "adversarial",
            "bin/glaw-adversarial status --profile auto",
            "final packet government-adversary manifest is blocked: " + summary,
        )
    if "citation-grounding" in row_ids or "glaw-legal-research" in owners:
        return (
            "legal-research",
            "bin/glaw-citation-gate status",
            "final packet citation grounding is blocked: " + summary,
        )
    if {"red-flags", "red-flag-accountability"} & row_ids or "glaw-red-flags" in owners:
        return (
            "red-flags",
            "bin/glaw-red-flags status",
            "final packet red-flag controls are blocked: " + summary,
        )
    return (
        "compliance",
        "bin/glaw-final-packet build --profile auto",
        "final packet compliance manifest is blocked: " + summary,
    )


def decision_signature(decision: dict) -> str:
    return "|".join([
        str(decision.get("stage", "")),
        str(decision.get("quality_state", "")),
        str(decision.get("next_gate", "")),
        str(decision.get("owner", "")),
        str(decision.get("next_command", "")),
    ])


def prior_same_route_count(d: Path, signature: str) -> int:
    rows = read_jsonl(d / "loop_decisions.jsonl")
    count = 0
    for row in reversed(rows):
        if row.get("decision_signature") == signature:
            count += 1
        else:
            break
    return count


def checker_for(decision: dict, d: Path, *, max_iterations: int, user_acceptance: list[str]) -> dict:
    signature = decision_signature(decision)
    prior_count = prior_same_route_count(d, signature)
    conscience_rc, conscience_out = run_tool(
        "glaw-conscience",
        "check-call",
        "--command",
        str(decision.get("next_command", "")),
        "--matter",
        d.name,
        "--json",
    )
    try:
        conscience = json.loads(conscience_out)
    except json.JSONDecodeError:
        conscience = {
            "status": "fail",
            "phase": "tool-call",
            "failures": [{"id": "conscience_output", "detail": conscience_out or "invalid JSON"}],
        }
    criteria = [
        {
            "id": "owner_named",
            "status": "pass" if bool(str(decision.get("owner", "")).strip()) else "fail",
            "detail": "next owner must be explicit",
        },
        {
            "id": "next_command_named",
            "status": "pass" if bool(str(decision.get("next_command", "")).strip()) else "fail",
            "detail": "next command must be explicit",
        },
        {
            "id": "reason_present",
            "status": "pass" if bool(str(decision.get("reason", "")).strip()) else "fail",
            "detail": "routing reason must be explicit",
        },
        {
            "id": "human_authority_boundary",
            "status": "pass" if "no filing/signing/service/payment/charge/live transmission" in str(decision.get("authority", "")) else "fail",
            "detail": "decision must preserve human-only authority boundary",
        },
        {
            "id": "iteration_cap",
            "status": "pass" if prior_count < max_iterations else "fail",
            "detail": f"same route repeated {prior_count} time(s); cap is {max_iterations}",
        },
        {
            "id": "conscience_call_guard",
            "status": "pass" if conscience_rc == 0 and conscience.get("status") == "pass" else "fail",
            "detail": "next command passes autonomous tool-call conscience checks",
        },
    ]
    for idx, text in enumerate(user_acceptance, start=1):
        criteria.append({
            "id": f"user_acceptance_{idx}",
            "status": "recorded" if text.strip() else "fail",
            "detail": text.strip(),
        })
    failed = [item for item in criteria if item["status"] == "fail"]
    return {
        "status": "pass" if not failed else "fail",
        "decision_signature": signature,
        "prior_same_route_count": prior_count,
        "max_iterations": max_iterations,
        "criteria": criteria,
        "failed": failed,
        "conscience": conscience,
    }


def apply_checker(decision: dict, checker: dict) -> dict:
    decision["checker"] = checker
    decision["decision_signature"] = checker["decision_signature"]
    if checker["status"] == "pass":
        return decision
    failed_ids = {item["id"] for item in checker.get("failed", [])}
    if "iteration_cap" in failed_ids:
        reason = (
            "glaw-loop reached its iteration cap without convergence; "
            "same route repeated "
            f"{checker.get('prior_same_route_count')} time(s)"
        )
        decision.update({
            "quality_state": "human_escalation_required",
            "next_gate": "oversight",
            "owner": "human-oversight-board",
            "next_command": "bin/glaw-oversight status",
            "reason": reason,
        })
        decision["oversight"] = oversight_escalate(matter=str(decision.get("matter", "")), reason=reason)
        decision["decision_signature"] = decision_signature(decision)
    return decision


def halted_decision(d: Path) -> dict | None:
    oversight = oversight_status(5)
    state = oversight.get("state") or {}
    if not state.get("halted"):
        return None
    track, profile = matter_profile(d)
    stage = (d / ".stage").read_text(encoding="utf-8").strip() if (d / ".stage").exists() else "intake"
    return {
        "ts": now(),
        "matter": d.name,
        "stage": stage,
        "workflow_track": track,
        "workflow_profile": profile,
        "quality_state": "human_escalation_required",
        "next_gate": "oversight",
        "owner": "human-oversight-board",
        "next_command": "bin/glaw-oversight status",
        "reason": f"kill-switch active: {state.get('halt_reason', 'halted by Oversight Board')}",
        "council_required": list(COUNCIL_PROFILES.get(profile, ())),
        "adversarial_required": list(ADVERSARIAL_PROFILES.get(profile, ())),
        "human_only_actions": sorted(HUMAN_ONLY_ACTIONS),
        "authority": "quality routing only; no filing/signing/service/payment/charge/live transmission",
        "oversight": oversight,
    }


def latched_escalation_decision(d: Path) -> dict | None:
    rows = read_jsonl(d / "loop_decisions.jsonl")
    for row in reversed(rows):
        if row.get("quality_state") != "human_escalation_required" or row.get("next_gate") != "oversight":
            continue
        oversight = oversight_status(5)
        resumed_at = str((oversight.get("state") or {}).get("resumed_at", ""))
        escalated_at = str(row.get("ts", ""))
        if resumed_at and escalated_at and resumed_at > escalated_at:
            return None
        track, profile = matter_profile(d)
        stage = (d / ".stage").read_text(encoding="utf-8").strip() if (d / ".stage").exists() else "intake"
        return {
            "ts": now(),
            "matter": d.name,
            "stage": stage,
            "workflow_track": track,
            "workflow_profile": profile,
            "quality_state": "human_escalation_required",
            "next_gate": "oversight",
            "owner": "human-oversight-board",
            "next_command": "bin/glaw-oversight status",
            "reason": "prior non-convergence escalation remains latched until Oversight Board resume",
            "council_required": list(COUNCIL_PROFILES.get(profile, ())),
            "adversarial_required": list(ADVERSARIAL_PROFILES.get(profile, ())),
            "human_only_actions": sorted(HUMAN_ONLY_ACTIONS),
            "authority": "quality routing only; no filing/signing/service/payment/charge/live transmission",
            "oversight": oversight,
            "latched_from": row.get("ts", ""),
        }
    return None


def route_from_state(d: Path) -> dict:
    slug = d.name
    stage = (d / ".stage").read_text(encoding="utf-8").strip() if (d / ".stage").exists() else "intake"
    rows = read_jsonl(d / "timeline.jsonl")
    track, profile = matter_profile(d)
    strategy_clear, strategy_output = gate_check("strategy", slug)
    file_clear, file_output = gate_check("file", slug)
    retro_clear, retro_output = gate_check("matter-retro", slug)

    decision = {
        "ts": now(),
        "matter": slug,
        "stage": stage,
        "workflow_track": track,
        "workflow_profile": profile,
        "quality_state": "blocked",
        "next_gate": "",
        "owner": "",
        "next_command": "",
        "reason": "",
        "council_required": list(COUNCIL_PROFILES.get(profile, ())),
        "adversarial_required": list(ADVERSARIAL_PROFILES.get(profile, ())),
        "human_only_actions": sorted(HUMAN_ONLY_ACTIONS),
        "authority": "quality routing only; no filing/signing/service/payment/charge/live transmission",
        "compliance_failures": [],
        "compliance_action_plan": [],
    }

    if not strategy_clear:
        missing_intake = not has_event(rows, "intake_complete")
        missing_conflicts = not has_event(rows, "conflicts_cleared")
        decision.update({
            "next_gate": "strategy",
            "owner": "intake/ethics",
            "next_command": "bin/glaw-intake status && bin/glaw-ethics status",
            "reason": strategy_output or "intake and conflicts must clear before strategy",
        })
        if missing_intake:
            decision["owner"] = "intake"
            decision["next_command"] = "bin/glaw-intake status"
        elif missing_conflicts:
            decision["owner"] = "ethics-conflicts"
            decision["next_command"] = "bin/glaw-ethics status"
        return decision

    if stage == "intake":
        decision.update({
            "quality_state": "ready_for_next_stage",
            "next_gate": "strategy",
            "owner": "orchestrator",
            "next_command": "bin/glaw stage strategy",
            "reason": "intake and conflicts are clear; strategy may begin",
        })
        return decision

    if not file_clear:
        if not has_event(rows, "citations_verified"):
            owner = "legal-research"
            command = "bin/glaw-citation-gate status"
        elif not has_event(rows, "adversarial_done"):
            owner = "adversarial"
            command = "bin/glaw-adversarial status --profile auto"
        elif not has_event(rows, "red_flags_clear"):
            owner = "red-flags"
            command = "bin/glaw-red-flags status"
        elif not has_event(rows, "final_packet_ready"):
            failures = final_packet_compliance_failures(d)
            if failures:
                owner, command, reason = compliance_failure_route(failures)
                decision["compliance_failures"] = failures
                decision["compliance_action_plan"] = final_packet_compliance_action_plan(d)
                decision["reason"] = reason
            else:
                owner = "final-packet"
                command = "bin/glaw-final-packet build --profile auto"
        elif not has_event(rows, "chief_approved"):
            owner = "chief-counsel"
            command = "bin/glaw-chief-decision --approve-final ..."
        else:
            owner = "file-gate"
            command = "bin/glaw-gate check file"
        decision.update({
            "next_gate": "file",
            "owner": owner,
            "next_command": command,
            "reason": decision.get("reason") or file_output or "file gate is not clear",
        })
        return decision

    if stage != "file":
        decision.update({
            "quality_state": "ready_for_next_stage",
            "next_gate": "file",
            "owner": "orchestrator",
            "next_command": "bin/glaw stage file",
            "reason": "all file quality gates are clear; filing still requires human authority",
        })
        return decision

    if not retro_clear:
        decision.update({
            "next_gate": "matter-retro",
            "owner": "docket",
            "next_command": "bin/glaw-docket-gate status",
            "reason": retro_output or "docket gate must clear before close-out",
        })
        return decision

    decision.update({
        "quality_state": "ready_for_closeout",
        "next_gate": "matter-retro",
        "owner": "matter-retro",
        "next_command": "bin/glaw stage matter-retro",
        "reason": "all quality gates are clear; close-out may proceed after human authority checks for any binding act",
    })
    return decision


def print_report(decision: dict) -> None:
    print(f"GLAW LOOP: {decision['matter']}")
    print(f"  stage: {decision['stage']}  track: {decision['workflow_track']}  profile: {decision['workflow_profile']}")
    print(f"  state: {decision['quality_state']}")
    print(f"  next gate: {decision['next_gate'] or '(none)'}")
    print(f"  owner: {decision['owner'] or '(none)'}")
    print(f"  next command: {decision['next_command'] or '(none)'}")
    print(f"  reason: {decision['reason'] or '(none)'}")
    if decision.get("adversarial_required"):
        print("  adversarial lenses: " + ", ".join(decision["adversarial_required"]))
    print("  authority: " + decision["authority"])
    checker = decision.get("checker") or {}
    if checker:
        print(f"  checker: {checker.get('status')}  repeat={checker.get('prior_same_route_count')}/{checker.get('max_iterations')}")
        for item in checker.get("failed", []):
            print(f"    failed: {item.get('id')} - {item.get('detail')}")


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(prog="glaw-loop")
    sub = ap.add_subparsers(dest="cmd", required=True)
    for name in ("status", "once"):
        p = sub.add_parser(name)
        p.add_argument("--matter", default=None)
        p.add_argument("--json", action="store_true")
        p.add_argument("--max-iterations", type=int, default=3)
        if name == "once":
            p.add_argument("--request-action", default="")
            p.add_argument("--role", default="")
            p.add_argument("--acceptance", action="append", default=[])
    args = ap.parse_args(argv)

    d = matter_dir(args.matter)
    requested = getattr(args, "request_action", "")
    if requested:
        ok, result = require_human_authority(requested, role=getattr(args, "role", ""), context=f"glaw-loop {d.name}")
        if not ok:
            row = {
                    "ts": now(),
                    "matter": d.name,
                    "quality_state": "authority_blocked",
                    "requested_action": requested,
                    "reason": result,
                }
            if args.cmd == "once":
                append_jsonl(d / "loop_decisions.jsonl", row)
            if args.json:
                print(json.dumps(row, indent=2))
            else:
                print(result)
            return 1

    decision = halted_decision(d) or latched_escalation_decision(d) or route_from_state(d)
    checker = checker_for(
        decision,
        d,
        max_iterations=max(1, int(args.max_iterations)),
        user_acceptance=getattr(args, "acceptance", []),
    )
    decision = apply_checker(decision, checker)
    if args.cmd == "once":
        append_jsonl(d / "loop_decisions.jsonl", decision)
    if args.json:
        print(json.dumps(decision, indent=2, sort_keys=False))
    else:
        print_report(decision)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
