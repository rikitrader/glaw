#!/usr/bin/env bash
# glaw-form990 — Form 990 family DRAFT: return gating (990-N/EZ/990/PF) + 990-T UBIT + support test.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
