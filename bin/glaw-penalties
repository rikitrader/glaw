#!/usr/bin/env bash
# glaw-penalties — IRS failure-to-file + failure-to-pay penalties + daily-compounded interest.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/penalties.py" "$@"
