#!/usr/bin/env bash
# glaw-dashboard — management KPI pack (margins, liquidity, DSO/DPO, leverage, burn) from the ledger.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/dashboard.py" "$@"
