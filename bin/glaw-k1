#!/usr/bin/env bash
# glaw-k1 — allocate pass-through ordinary income + separately-stated items to owners (Schedule K-1).
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/k1.py" "$@"
