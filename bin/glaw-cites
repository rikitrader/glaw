#!/usr/bin/env bash
# glaw-cites — deterministic legal-citation EXTRACTOR (Free Law Project eyecite).
# Runs under the bookkeeping venv (where eyecite is installed), matching the firm's
# bin-wrapper idiom. Pulls every case/statute/short-form cite for /glaw-legal-research
# to VERIFY. Usage: glaw-cites <file|-> [--json]   (stdin via -)
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/cites.py" "$@"
