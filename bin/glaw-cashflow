#!/usr/bin/env bash
# glaw-cashflow — indirect-method statement of cash flows from the ledger (tag-aware).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_LIB="$(cd "$SCRIPT_DIR/../lib/bookkeeping" && pwd)"
GLAW_LIB="${GLAW:+$GLAW/lib/bookkeeping}"
[ -n "${GLAW_LIB:-}" ] && [ -d "$GLAW_LIB" ] || GLAW_LIB="$SCRIPT_LIB"
PY="$(command -v python3)"
exec "$PY" "$GLAW_LIB/cashflow_cli.py" "$@"
