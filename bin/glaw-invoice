#!/usr/bin/env bash
# glaw-invoice — extract a vendor invoice/bill (vendor, line items, tax, total) → draft AP entry.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/invoice_extract.py" "$@"
