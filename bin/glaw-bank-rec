#!/usr/bin/env bash
# glaw-bank-rec — true bank reconciliation: line-match the books against the bank
# statement, surfacing book-only (deposits in transit / outstanding checks) and
# bank-only (fees / interest to record) items. Exit 0 only if fully reconciled.
#
# Usage:
#   glaw-bank-rec --books books.json   --bank statement.json
#   glaw-bank-rec --books books.csv    --bank bank.ofx        # raw source files auto-ingested
#   glaw-bank-rec --books b.json --bank k.json --window 7 --format json
#
# --books / --bank accept either a glaw-bank-ingest JSON or a source statement file
# (CSV/OFX/QFX/MT940/CAMT/PAIN), which is ingested to JSON first.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_LIB="$(cd "$SCRIPT_DIR/../lib/bookkeeping" && pwd)"
GLAW_LIB="${GLAW:+$GLAW/lib/bookkeeping}"
[ -n "${GLAW_LIB:-}" ] && [ -d "$GLAW_LIB" ] || GLAW_LIB="$SCRIPT_LIB"
INGEST="$SCRIPT_DIR/glaw-bank-ingest"
PY="$(command -v python3)"

BOOKS=""; BANK=""; PASS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --books) BOOKS="$2"; shift 2;;
    --bank)  BANK="$2";  shift 2;;
    *) PASS+=("$1"); shift;;
  esac
done
[[ -n "$BOOKS" && -n "$BANK" ]] || { echo "ERROR: --books and --bank are required" >&2; exit 2; }

TMP="$(mktemp -d)"; trap 'rm -rf "$TMP"' EXIT
# Convert a raw statement to ingest JSON; pass .json through unchanged.
to_json() {
  case "$1" in
    *.json) printf '%s' "$1";;
    *) "$INGEST" "$1" --format json >"$TMP/$2.json" 2>/dev/null; printf '%s' "$TMP/$2.json";;
  esac
}
BJ="$(to_json "$BOOKS" books)"
KJ="$(to_json "$BANK" bank)"
exec "$PY" "$GLAW_LIB/bank_rec.py" --books "$BJ" --bank "$KJ" ${PASS[@]+"${PASS[@]}"}
