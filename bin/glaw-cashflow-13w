#!/usr/bin/env bash
# glaw-cashflow-13w — 13-week cash-flow projection from a plan JSON; flags weeks below minimum.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/cashflow13.py" "$@"
