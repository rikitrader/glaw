#!/usr/bin/env python3
"""GLAW review council ledger for required multi-agent signoff."""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))
from glaw_profiles import COUNCIL_PROFILES as PROFILES
from glaw_profiles import profile_for_track


SOURCE_EVIDENCE_PARTS = {"evidence", "source_documents", "sources"}


def now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def slugify(text: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")


def home() -> Path:
    return Path(os.environ.get("GLAW_HOME", str(Path.home() / ".glaw")))


def active_slug() -> str:
    p = home() / ".active"
    return p.read_text(encoding="utf-8").strip() if p.exists() else ""


def matter_dir(slug: str | None) -> Path:
    s = slug or active_slug()
    if not s:
        raise SystemExit("ERROR: no active matter. Run `glaw matter new \"<name>\"` first.")
    d = home() / "matters" / s
    if not d.is_dir():
        raise SystemExit(f"ERROR: matter not found: {s}")
    return d


def append_jsonl(path: Path, row: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, sort_keys=False) + "\n")


def row_hash(row: dict) -> str:
    payload = dict(row)
    payload.pop("row_hash", None)
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def stamp_row_hash(row: dict) -> dict:
    row["row_hash"] = row_hash(row)
    return row


def validate_row_hashes(rows: list[dict], ledger_name: str) -> list[str]:
    failures = []
    for idx, row in enumerate(rows, start=1):
        expected = row.get("row_hash")
        if not expected:
            failures.append(f"{ledger_name}:{idx} missing row_hash")
        elif expected != row_hash(row):
            failures.append(f"{ledger_name}:{idx} row_hash mismatch")
    return failures


def evidence_source_ids(evidence: str) -> list[str]:
    return sorted(set(re.findall(r"\bSRC-\d{4}\b", evidence)))


def is_source_evidence(path: Path, root: Path) -> bool:
    if not path.is_file():
        return False
    return bool(set(path.relative_to(root).parts) & SOURCE_EVIDENCE_PARTS)


def current_source_ids(d: Path) -> set[str]:
    paths = [p for p in d.rglob("*") if is_source_evidence(p, d) and p.stat().st_size > 0]
    return {f"SRC-{idx:04d}" for idx, _path in enumerate(sorted(paths), start=1)}


def noncurrent_source_ids(evidence: str, d: Path) -> list[str]:
    cited = set(evidence_source_ids(evidence))
    if not cited:
        return []
    current = current_source_ids(d)
    return sorted(cited - current)


def read_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    out = []
    for idx, line in enumerate(path.read_text(encoding="utf-8", errors="replace").splitlines(), start=1):
        if line.strip():
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError as exc:
                raise SystemExit(f"ERROR: {path.name}:{idx} invalid JSON: {exc.msg}") from exc
    return out


def latest_by_role(rows: list[dict]) -> dict[str, dict]:
    latest: dict[str, dict] = {}
    for row in rows:
        latest[row.get("role", "")] = row
    return latest


def timeline(d: Path, event: str, **extra: object) -> None:
    row = {"ts": now(), "event": event, **extra}
    append_jsonl(d / "timeline.jsonl", row)


def intake_profile(d: Path) -> str:
    p = d / "intake.json"
    if not p.exists():
        return "hybrid"
    try:
        form = json.loads(p.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return "hybrid"
    track = form.get("universal", {}).get("workflow_track") or form.get("workflow_track")
    return profile_for_track(track)


def profile_for(args: argparse.Namespace, d: Path) -> str:
    return args.profile if args.profile != "auto" else intake_profile(d)


def add_red_flag(d: Path, *, profile: str, role: str, severity: str, finding: str,
                 conditions: list[str], notes: str) -> None:
    existing = read_jsonl(d / "red_flags.jsonl")
    rid = f"RF-{len(existing) + 1:04d}"
    row = {
        "ts": now(),
        "id": rid,
        "severity": severity,
        "owner": role,
        "source": f"council:{profile}:{role}",
        "finding": finding,
        "required_fix": "; ".join(conditions) if conditions else (notes or "Resolve council finding."),
        "status": "open",
        "resolution_evidence": "",
    }
    append_jsonl(d / "red_flags.jsonl", row)
    timeline(d, "red_flag_opened", id=rid, severity=severity, owner=role, source=row["source"])


def cmd_record(args: argparse.Namespace) -> int:
    d = matter_dir(args.matter)
    profile = profile_for(args, d)
    role = slugify(args.role)
    decision = args.decision.lower()
    if decision not in {"approve", "fix", "deny"}:
        raise SystemExit("ERROR: decision must be approve, fix, or deny")
    if decision == "approve":
        if not args.evidence.strip():
            raise SystemExit("ERROR: council approve requires --evidence with the source-backed review basis.")
        if not evidence_source_ids(args.evidence):
            raise SystemExit("ERROR: council approve evidence must cite a source artifact ID such as SRC-0001.")
        if not args.notes.strip():
            raise SystemExit("ERROR: council approve requires --notes with the role-specific conclusion.")
    if decision == "fix" and (not args.red_flags.strip() or not args.conditions.strip()):
        raise SystemExit("ERROR: council fix requires --red-flags and --conditions.")
    if decision == "deny" and not args.red_flags.strip():
        raise SystemExit("ERROR: council deny requires --red-flags.")
    if decision in {"fix", "deny"} and not evidence_source_ids(" ".join([args.red_flags, args.notes])):
        raise SystemExit("ERROR: council fix/deny red flags must cite a source artifact ID such as SRC-0001.")
    row = {
        "ts": now(),
        "profile": profile,
        "role": role,
        "display_role": args.role,
        "decision": decision,
        "red_flags": [x.strip() for x in re.split(r"[;\n]", args.red_flags or "") if x.strip()],
        "conditions": [x.strip() for x in re.split(r"[;\n]", args.conditions or "") if x.strip()],
        "notes": args.notes,
        "evidence": args.evidence,
    }
    append_jsonl(d / "council.jsonl", stamp_row_hash(row))
    timeline(d, "council_review", profile=profile, role=role, decision=decision)
    if decision == "approve":
        timeline(d, f"council_approved_{role}", profile=profile)
    elif decision == "deny":
        timeline(d, f"council_denied_{role}", profile=profile)
    if decision in {"fix", "deny"}:
        severity = "critical" if decision == "deny" else "high"
        finding = args.red_flags or args.notes or f"{role} requested {decision}"
        add_red_flag(d, profile=profile, role=role, severity=severity,
                     finding=finding, conditions=row["conditions"], notes=args.notes)
    print(f"RECORDED {profile} council review: {role}={decision}")
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    d = matter_dir(args.matter)
    profile = profile_for(args, d)
    required = PROFILES[profile]
    rows = read_jsonl(d / "council.jsonl")
    hash_failures = validate_row_hashes(rows, "council.jsonl")
    if hash_failures:
        print("COUNCIL BLOCKED: ledger row hash failure")
        for failure in hash_failures:
            print(f"  {failure}")
        return 1
    latest = latest_by_role([r for r in rows if r.get("profile") == profile])
    failures = []
    current_sources = current_source_ids(d)
    print(f"COUNCIL {profile} — {d.name}")
    for role in required:
        row = latest.get(role)
        if not row:
            print(f"  ❌ {role}: missing")
            failures.append(role)
            continue
        decision = row.get("decision")
        evidence = str(row.get("evidence", ""))
        notes = str(row.get("notes", ""))
        evidence_gap = decision == "approve" and not evidence.strip()
        source_id_gap = decision == "approve" and not evidence_source_ids(evidence)
        noncurrent_source_gap = decision == "approve" and bool(noncurrent_source_ids(evidence, d))
        no_source_artifacts_gap = decision == "approve" and bool(evidence_source_ids(evidence)) and not current_sources
        notes_gap = decision == "approve" and not notes.strip()
        icon = "✅" if (
            decision == "approve"
            and not evidence_gap
            and not source_id_gap
            and not noncurrent_source_gap
            and not no_source_artifacts_gap
            and not notes_gap
        ) else "❌"
        print(f"  {icon} {role}: {decision}")
        for flag in row.get("red_flags", []):
            print(f"      red_flag: {flag}")
        for condition in row.get("conditions", []):
            print(f"      condition: {condition}")
        if evidence_gap:
            print("      evidence: MISSING")
        if source_id_gap:
            print("      source evidence id: MISSING")
        if no_source_artifacts_gap:
            print("      current source artifact: MISSING")
        if noncurrent_source_gap:
            print(f"      non-current source id: {', '.join(noncurrent_source_ids(evidence, d))}")
        if notes_gap:
            print("      notes/conclusion: MISSING")
        if decision != "approve" or evidence_gap or source_id_gap or noncurrent_source_gap or no_source_artifacts_gap or notes_gap:
            failures.append(role)
    if failures:
        print("COUNCIL BLOCKED")
        return 1
    print("COUNCIL READY")
    return 0


def cmd_complete(args: argparse.Namespace) -> int:
    d = matter_dir(args.matter)
    args.profile = profile_for(args, d)
    rc = cmd_status(args)
    if rc != 0:
        return rc
    timeline(d, f"{args.profile}_council_complete", profile=args.profile)
    print(f"{args.profile.upper()} COUNCIL COMPLETE")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="glaw-council")
    sub = ap.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("record", help="record one council lens review")
    p.add_argument("--profile", default="auto", choices=["auto", *sorted(PROFILES)])
    p.add_argument("--role", required=True, help="e.g. cfo, irs-audit-agent, legal-counsel")
    p.add_argument("--decision", required=True, choices=["approve", "fix", "deny"])
    p.add_argument("--red-flags", default="")
    p.add_argument("--conditions", default="")
    p.add_argument("--notes", default="")
    p.add_argument("--evidence", default="")
    p.add_argument("--matter", default=None)
    p.set_defaults(func=cmd_record)
    p = sub.add_parser("status", help="show council completion status")
    p.add_argument("--profile", default="auto", choices=["auto", *sorted(PROFILES)])
    p.add_argument("--matter", default=None)
    p.set_defaults(func=cmd_status)
    p = sub.add_parser("complete", help="log <profile>_council_complete when every lens approves")
    p.add_argument("--profile", default="auto", choices=["auto", *sorted(PROFILES)])
    p.add_argument("--matter", default=None)
    p.set_defaults(func=cmd_complete)
    args = ap.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
