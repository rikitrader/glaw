#!/usr/bin/env bash
# glaw-sales-use-tax — economic-nexus determination + sales-tax-due schedule, reconciled to the GL.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/sales_use_tax.py" "$@"
