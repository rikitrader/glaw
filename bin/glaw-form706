#!/usr/bin/env bash
# glaw-form706 — Form 706 estate-tax DRAFT (taxable estate, §2001(c) tax, unified credit, DSUE).
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/form706.py" "$@"
