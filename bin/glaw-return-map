#!/usr/bin/env bash
# glaw-return-map — populate 1120/1120-S/1065/Schedule C return lines from the posted GL + M-1.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/return_map.py" "$@"
