#!/usr/bin/env python3
"""glaw-tax-report — GLAW's structured tax-compliance data object.

Schema vendored + extended from api-evangelist/tax-reporting-templates
(lib/schemas/tax-report-schema.json; GLAW added 1120-S / Schedule K-1 for
pass-throughs). Gives the Tax & IRS division a machine-VALIDATABLE object to sit
under the prose memos and the docket — and a clean handoff to tax software.

Usage:
  glaw-tax-report types               list valid report_type values
  glaw-tax-report validate <file>     validate a tax-report JSON against the schema
  glaw-tax-report scaffold <type>     print a blank report skeleton for a report_type
"""
import sys, json, os, re

SCHEMA = os.path.expanduser("~/.claude/skills/glaw/lib/schemas/tax-report-schema.json")

def load(): return json.load(open(SCHEMA))

def _resolve(schema, ref):
    if not ref.startswith("#/$defs/"):
        return {}
    cur = schema.get("$defs", {})
    for part in ref[len("#/$defs/"):].split("/"):
        cur = cur.get(part, {})
    return cur

def _type_ok(value, typ):
    if typ == "object": return isinstance(value, dict)
    if typ == "array": return isinstance(value, list)
    if typ == "string": return isinstance(value, str)
    if typ == "integer": return isinstance(value, int) and not isinstance(value, bool)
    if typ == "number": return (isinstance(value, (int, float)) and not isinstance(value, bool))
    if typ == "boolean": return isinstance(value, bool)
    return True

def _validate_node(root, node, value, path, errors):
    if "$ref" in node:
        node = _resolve(root, node["$ref"])
    typ = node.get("type")
    if typ and not _type_ok(value, typ):
        errors.append((path or "(root)", f"expected {typ}, got {type(value).__name__}"))
        return
    if "enum" in node and value not in node["enum"]:
        errors.append((path or "(root)", f"value {value!r} is not one of {node['enum']}"))
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        if "minimum" in node and value < node["minimum"]:
            errors.append((path or "(root)", f"value {value!r} is below minimum {node['minimum']}"))
        if "maximum" in node and value > node["maximum"]:
            errors.append((path or "(root)", f"value {value!r} is above maximum {node['maximum']}"))
    if isinstance(value, str) and "pattern" in node and not re.match(node["pattern"], value):
        errors.append((path or "(root)", f"value {value!r} does not match pattern {node['pattern']}"))
    if isinstance(value, dict):
        for key in node.get("required", []):
            if key not in value:
                errors.append((f"{path}.{key}" if path else key, "required field missing"))
        for key, child in node.get("properties", {}).items():
            if key in value:
                _validate_node(root, child, value[key], f"{path}.{key}" if path else key, errors)

def validate(schema, data):
    errors = []
    _validate_node(schema, schema, data, "", errors)
    return errors

def cmd_types():
    s = load()
    print("valid report_type values:")
    for t in s["properties"]["report_type"]["enum"]:
        print("  -", t)

def cmd_validate(path):
    s = load()
    data = json.load(open(path))
    errs = validate(s, data)
    if not errs:
        print(f"VALID ✅  {os.path.basename(path)}  (report_type={data.get('report_type')}, tax_year={data.get('tax_year')})")
        return 0
    print(f"INVALID ❌  {os.path.basename(path)} — {len(errs)} error(s):")
    for path, msg in errs[:12]:
        print("  -", path, ":", msg)
    return 2

def cmd_scaffold(rtype):
    s = load()
    skel = {"report_type": rtype, "tax_year": 0, "period": "annual",
            "filing_status": "draft",
            "filer": {"name": "", "tin_type": "EIN", "tin": "",
                      "filing_type": "s-corp",
                      "address": {"street": "", "city": "", "state": "", "zip": "", "country": "US"}},
            "income": {}, "deductions": {}, "taxes": {}, "payments": {},
            "metadata": {"preparer_name": "GLAW (attorney/CPA review required)"}}
    print(json.dumps(skel, indent=2))

if __name__ == "__main__":
    a = sys.argv[1:]
    if not a or a[0] == "types": cmd_types()
    elif a[0] == "validate" and len(a) > 1: sys.exit(cmd_validate(a[1]))
    elif a[0] == "scaffold" and len(a) > 1: cmd_scaffold(a[1])
    else: print(__doc__)
