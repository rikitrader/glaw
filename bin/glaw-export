#!/usr/bin/env bash
# glaw-export — styled, printable financial report (HTML, print-to-PDF) from the ledger.
# Optional --gsheet pushes the trial balance to a Google Sheet (needs ~/.gcp/token.json).
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/export_report.py" "$@"
