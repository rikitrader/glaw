  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance40.py" >/dev/null 2>&1; then
    ok "back-filing/SFR/installment passed (multi-year roll + collection plan)"
  else
    bad "back-filing FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance40.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance41.py" >/dev/null 2>&1; then
    ok "OIC/collections/TFRP passed (RCP + CNC/CDP + trust-fund recovery)"
  else
    bad "OIC FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance41.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance42.py" >/dev/null 2>&1; then
    ok "forensic pipeline passed (CSV -> double-entry GL, balanced, idempotent, review-flagged)"
  else
    bad "forensic-pipeline FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance42.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance43.py" >/dev/null 2>&1; then
    ok "forensic deliverables passed (8 audit-ready reports from the GL + gap detection)"
  else
    bad "forensic-deliverables FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance43.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance44.py" >/dev/null 2>&1; then
    ok "forensic monthly/yearly reports passed (period P&L + full transaction trace)"
  else
    bad "forensic-reports FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance44.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance45.py" >/dev/null 2>&1; then
    ok "forensic adversarial gate passed (executable red-team + chief resolution)"
  else
    bad "forensic-adversarial FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance45.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance46.py" >/dev/null 2>&1; then
    ok "entity engines passed (S-corp basis/AAA, partner basis, penalty taxes, 1041)"
  else
    bad "entity engines FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance46.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance47.py" >/dev/null 2>&1; then
    ok "state tax engines passed (state income, PTET, franchise/margin, combined, nexus, sourcing)"
  else
    bad "state engines FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance47.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance48.py" >/dev/null 2>&1; then
    ok "international engines passed (GILTI, Subpart F, FDII, BEAT, 163j, 5471/5472)"
  else
    bad "intl engines FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance48.py"
  fi
  if python3 "$GLAW/lib/federal-litigation/test_fed_causes.py" >/dev/null 2>&1; then
    ok "federal causes library passed (56 causes + CLI + 8 complaints + statute excerpts)"
  else
    bad "federal-causes FAILED — run: python3 $GLAW/lib/federal-litigation/test_fed_causes.py"
  fi
  if printf '' | "$GLAW/bin/glaw-writing-check" - >/dev/null 2>&1 && python3 "$GLAW/lib/writing/test_writing_check.py" >/dev/null 2>&1; then
    ok "legal-writing QC passed (glaw-writing-check linter + motion profile)"
  else
    bad "writing-check FAILED — run: python3 $GLAW/lib/writing/test_writing_check.py"
  fi
  if python3 "$GLAW/lib/render/test_federal_format.py" >/dev/null 2>&1; then
    ok "federal render profile passed (generate→conforms, plain→fails — TNR/double/justified/1.25\" + page #s)"
  else
    bad "federal-format FAILED — run: python3 $GLAW/lib/render/test_federal_format.py"
  fi
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_wiring.py" >/dev/null 2>&1; then
    ok "orchestrator-wiring lock passed (/glaw-accounting routes to the finance subsystem)"
  else
    bad "wiring lock FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_wiring.py"
  fi
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_bin_scorers.py" >/dev/null 2>&1; then
    ok "bin-scorer locks passed (bureau-score clamp/weights + contract-score bound)"
  else
    bad "bin-scorer locks FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_bin_scorers.py"
  fi
else
  if printf 'date,description,amount\n2026-01-01,Doctor smoke,1.00\n' > /tmp/glaw-doctor-bank.csv \
     && GLAW="$GLAW" "$GLAW/bin/glaw-bank-ingest" /tmp/glaw-doctor-bank.csv --format json >/dev/null 2>&1; then
    ok "zero-dependency bookkeeping smoke passed (CSV ingest via in-repo glaw_engine)"
  else
    bad "zero-dependency bookkeeping smoke FAILED — run: GLAW=$GLAW $GLAW/bin/glaw-bank-ingest /tmp/glaw-doctor-bank.csv --format json"
  fi
  if [ -x "$GLAW/bin/glaw-bookkeeping-doctor" ]; then
    if GLAW="$GLAW" "$GLAW/bin/glaw-bookkeeping-doctor" >/tmp/glaw-bookkeeping-doctor.out 2>&1; then
      ok "bookkeeping/IRS/adversarial gate passed (bank rec + ledger + forms + tax tie-out)"
    else
      bad "bookkeeping/IRS/adversarial gate FAILED — run: GLAW=$GLAW $GLAW/bin/glaw-bookkeeping-doctor"
      grep -E '❌|Traceback|ERROR' /tmp/glaw-bookkeeping-doctor.out | sed 's/^/    /'
    fi
  else
    bad "glaw-bookkeeping-doctor missing/executable bit absent"
  fi
fi
# scripts: syntax-check (don't execute — they mutate/source)
for s in glaw-setup glaw-preamble.sh glaw-gate; do
  bash -n "$GLAW/bin/$s" 2>/dev/null && ok "$s syntax OK" || bad "$s syntax error"
done
# matter-ops/*.py: compile-check (they mutate state / hit network — never execute in doctor).
# Includes the safety-critical launch-guard engine facts_validate.py + facts_gate.py.
mo_fail=0; mo_n=0
for p in "$GLAW"/bin/matter-ops/*.py; do
  [ -f "$p" ] || continue; mo_n=$((mo_n+1))
  python3 -m py_compile "$p" 2>/dev/null || { bad "matter-ops/$(basename "$p") syntax error"; mo_fail=$((mo_fail+1)); }
done
[ "$mo_fail" = 0 ] && ok "all $mo_n bin/matter-ops/*.py compile (incl. facts_validate/facts_gate guard)"
# regression tests (safety-critical paths): launch-guard, hard gates, full lifecycle, profile routing
for t in facts_validate_test:launch-guard gate_test:hard-gate lifecycle_test:full-lifecycle tax_profile_test:tax-profile sec_reporting_profile_test:sec-reporting-profile authority_gate_test:authority-gate rbac_test:rbac-soc2 host_adapter_test:host-adapter mcp_test:mcp-bridge extism_test:extism-contract headless_test:headless-report constitutional_test:constitutional-branch oversight_test:oversight-board conscience_test:autonomous-conscience citation_corpus_test:citation-corpus citation_typology_test:citation-typology groundedness_test:groundedness policy_test:policy-contract loop_test:orchestrator-loop golden_profile_test:golden-profiles memory_test:cross-matter-memory; do
  script="$GLAW/test/${t%%:*}.sh"; name="${t#*:}"
  [ -x "$script" ] || continue
  if "$script" >/tmp/glaw-$$.out 2>&1; then
    ok "$name test: $(grep -oE '[0-9]+ passed' /tmp/glaw-$$.out | head -1)"
  else
    bad "$name test FAILED — run: $script"; grep -E '✗|FAIL' /tmp/glaw-$$.out | sed 's/^/    /'
  fi
done; rm -f /tmp/glaw-$$.out

# ---- 3. NO DANGLING REFS ----
echo "[3/3] self-contained ecosystem — no dangling references"
ROSTER="$GLAW/lib/firm-roster.md"

# 3a. MANIFEST BIJECTION (deterministic, no prose parsing): seats/MANIFEST is the single
#     source of truth for vendored seats. It must match seats/ exactly — no missing, no
#     orphan — and every seat is a real skill (has SKILL.md). Nothing is "ignored".
MAN="$GLAW/seats/MANIFEST"
man=0
if [ ! -f "$MAN" ]; then bad "seats/MANIFEST missing"; man=1; else
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    [ -f "$GLAW/seats/$name/SKILL.md" ] || { bad "MANIFEST lists '$name' but seats/$name/SKILL.md is missing"; man=$((man+1)); }
  done < "$MAN"
  for d in "$GLAW"/seats/*/; do
    [ -d "$d" ] || continue
    b="$(basename "$d")"
    grep -qxF "$b" "$MAN" || { bad "seats/$b exists but is not in MANIFEST (orphan)"; man=$((man+1)); }
    [ -f "$d/SKILL.md" ] || { bad "seats/$b has no SKILL.md"; man=$((man+1)); }
  done
fi
[ "$man" = 0 ] && ok "manifest bijection: $(grep -c . "$MAN" 2>/dev/null) seats, all present with SKILL.md (no orphans)"

# 3b. REFERENCE RESOLUTION (no ignored tokens): every glaw-* skill reference — written as
#     /glaw-x or `glaw-x` anywhere in the roster or any SKILL.md — must resolve to a real
#     thing: a glaw sub-skill ($GLAW/x), a vendored seat ($GLAW/seats/glaw-x), a bin tool
#     ($GLAW/bin/glaw-x), or an installed sibling ($ROOT/glaw-x). The glaw- prefix makes
#     every routing target self-identifying, so there is NO prose noise to ignore.
ref=0
# Strip bin/asset/forms-library tool paths first (checked as files, not skills), then
# extract /glaw-x and `glaw-x` skill-invocation references.
# Strip bin/asset/forms-library/<skill>/ file paths from FULL lines first (these are
# files, not skill invocations), THEN extract the remaining /glaw-x and `glaw-x` refs.
STRIP='s#(bin|assets|forms-library|[a-z0-9-]+)/glaw-[a-z0-9._-]*##g'
TOKENS=$( { grep -rhE '/glaw-[a-z0-9-]+'   "$ROSTER" "$GLAW"/*/SKILL.md "$GLAW"/seats/*/SKILL.md 2>/dev/null | sed -E "$STRIP" | grep -oE '/glaw-[a-z0-9-]+' | sed 's#/##';
            grep -rhoE '`glaw-[a-z0-9-]+`' "$ROSTER" "$GLAW"/*/SKILL.md "$GLAW"/seats/*/SKILL.md 2>/dev/null | tr -d '`'; } | sort -u )
for t in $TOKENS; do
  [ "$t" = "glaw" ] && continue
  x="${t#glaw-}"
  [ -f "$GLAW/$x/SKILL.md" ]        && continue   # glaw sub-skill (strategy, draft, ...)
  [ -f "$GLAW/seats/$t/SKILL.md" ]  && continue   # vendored seat (glaw-financial-forensics, ...)
  [ -e "$GLAW/bin/$t" ] || ls "$GLAW"/bin/"$t".* >/dev/null 2>&1 && continue   # bin tool (any ext)
  [ -e "$ROOT/$t/SKILL.md" ]        && continue   # installed sibling
  bad "reference /$t resolves to no skill, seat, or tool (gap)"; ref=$((ref+1))
done
[ "$ref" = 0 ] && ok "every glaw-* reference resolves ($(echo "$TOKENS" | grep -c .) refs, 0 ignored)"

# 3b-2. Non-seat token allowlist must exist and only name real backticked roster
#       tokens that are intentionally not vendorable skills.
nonseat=0
NONSEAT="$GLAW/seats/.nonseat-tokens"
if [ ! -f "$NONSEAT" ]; then
  bad "seats/.nonseat-tokens missing (required allowlist for non-vendored roster tokens)"
  nonseat=$((nonseat+1))
else
  while IFS= read -r token; do
    token="$(printf '%s' "$token" | sed -E 's/[[:space:]]+#.*$//; s/^[[:space:]]+//; s/[[:space:]]+$//')"
    [ -z "$token" ] && continue
    if ! grep -RInF "\`$token\`" "$ROSTER" "$GLAW/SKILL.md" "$GLAW"/*/SKILL.md "$GLAW/docs" "$GLAW/README.md" 2>/dev/null | grep -q .; then
      bad "seats/.nonseat-tokens contains unreferenced token: $token"
      nonseat=$((nonseat+1))
    fi
  done < "$NONSEAT"
fi
[ "$nonseat" = 0 ] && ok "non-seat token allowlist present and referenced"

# 3b-2b. Shared tax/legal figure spine must exist and be fresh enough that tax
#        math cannot silently depend on an undated or stale figures file.
if python3 - "$GLAW" <<'PY'
from __future__ import annotations

import datetime as dt
import pathlib
import re
import sys

glaw = pathlib.Path(sys.argv[1]).resolve()
base = glaw / "tax-legal-shared"
required = [
    base / "current-figures.md",
    base / "guardrails.md",
    base / "evals.md",
    base / "REVERIFY.md",
]
failures: list[str] = []
for path in required:
    if not path.is_file():
        failures.append(f"missing {path.relative_to(glaw)}")

figures = base / "current-figures.md"
if figures.is_file():
    text = figures.read_text(encoding="utf-8", errors="replace")
    date_match = re.search(r"^updated_as_of:\s*([0-9]{4}-[0-9]{2}-[0-9]{2})\s*$", text, re.M)
    age_match = re.search(r"^max_age_days:\s*([0-9]+)\s*$", text, re.M)
    if not date_match:
        failures.append("tax-legal-shared/current-figures.md missing updated_as_of")
    if not age_match:
        failures.append("tax-legal-shared/current-figures.md missing max_age_days")
    if date_match and age_match:
        updated = dt.date.fromisoformat(date_match.group(1))
        max_age = int(age_match.group(1))
        today = dt.date.today()
        if updated > today:
            failures.append("tax-legal-shared/current-figures.md updated_as_of is in the future")
        elif (today - updated).days > max_age:
            failures.append(
                "tax-legal-shared/current-figures.md is stale: "
                f"{(today - updated).days} days old, max {max_age}"
            )
    if "figure_id: FIG-YYYY-####" not in text:
        failures.append("tax-legal-shared/current-figures.md missing required entry shape")

if failures:
    for failure in failures:
        print(failure)
    sys.exit(1)
print("tax/legal figures spine exists and is within max age")
PY
then
  ok "tax/legal figures spine present and fresh"
else
  bad "tax/legal figures spine failed"
fi

# 3b-3. Profile SSOT consistency: every reviewer/lens named by the executable
#       council/adversarial profiles must map to a real skill carrying the identity
#       posture markers required by final-packet reviewer manifests.
if python3 - "$GLAW" <<'PY'
import pathlib
import sys

glaw = pathlib.Path(sys.argv[1]).resolve()
sys.path.insert(0, str(glaw / "lib"))
from glaw_profiles import ADVERSARIAL_PROFILES, COUNCIL_PROFILES, REVIEWER_SKILL_MAP


def skill_name(path: pathlib.Path) -> str:
    in_frontmatter = False
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.strip() == "---":
            if not in_frontmatter:
                in_frontmatter = True
                continue
            break
        if in_frontmatter and line.startswith("name:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""


skill_paths: dict[str, list[pathlib.Path]] = {}
for path in glaw.rglob("SKILL.md"):
    if ".git" in path.parts:
        continue
    name = skill_name(path)
    if name:
        skill_paths.setdefault(name, []).append(path)

failures: list[str] = []
for profile_kind, profiles in (
    ("council", COUNCIL_PROFILES),
    ("adversarial", ADVERSARIAL_PROFILES),
):
    for profile, reviewers in profiles.items():
        for reviewer in reviewers:
            skill = REVIEWER_SKILL_MAP.get(reviewer)
            if not skill:
                failures.append(f"{profile_kind}:{profile}:{reviewer} missing REVIEWER_SKILL_MAP entry")
                continue
            matches = sorted(skill_paths.get(skill, []), key=lambda p: ("seats" in p.relative_to(glaw).parts, str(p.relative_to(glaw))))
            if not matches:
                failures.append(f"{profile_kind}:{profile}:{reviewer} maps to {skill}, but no SKILL.md has that name")
                continue
            text = matches[0].read_text(encoding="utf-8", errors="replace")
            missing = [marker for marker in ("Identity:", "Soul:", "Report voice:") if marker not in text]
            if missing:
                failures.append(
                    f"{profile_kind}:{profile}:{reviewer} -> {skill} missing {', '.join(missing)}"
                )

if failures:
    for failure in failures:
        print(failure)
    sys.exit(1)
print("profile reviewer map resolves")
PY
then
  ok "profile consistency: every council/adversarial reviewer maps to a real identity-bearing skill"
else
  bad "profile consistency failed"
fi

# 3c. lib/ paths referenced -> exist
dlib=0
