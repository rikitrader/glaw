# ---- 5. CAPABILITY HONESTY (no false LIVE claims for LoRA/EWC neural learning) ----
echo "[5/5] capability honesty (glaw-capability-audit)"
if [ -x "$GLAW/bin/glaw-capability-audit" ]; then
  if "$GLAW/bin/glaw-capability-audit" >/tmp/glaw-cap.out 2>&1; then
    ok "no false LIVE claims — LoRA/EWC honestly scoped (📐 DESIGNED)"
  else
