if grep -RInP 'glaw-council record[^\n]*--decision approve(?![^\n]*--notes)|glaw-adversarial record[^\n]*--decision survive(?![^\n]*--attack)' \
   "$GLAW/SKILL.md" "$GLAW"/*/SKILL.md "$GLAW"/seats/*/SKILL.md "$GLAW/docs" "$GLAW/README.md" "$GLAW/test" "$GLAW/bin" "$GLAW/lib" 2>/dev/null \
   | grep -vE '/bin/glaw-doctor:' | grep -q .; then
  bad "review-gate documentation drift: council approve examples need --notes and adversarial survive examples need --attack"
