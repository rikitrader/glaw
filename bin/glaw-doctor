echo "[6/6] no secrets, keys, or personal data (content scan)"
# Root-cause guard: the committed tree must never carry live secrets, credential
# files, or personal/case data. Scans content, not just filenames. Excludes the
# ignored generated caches and documented EXAMPLE placeholders.
SCANROOT="$GLAW"
scan() { grep -rIE "$1" "$SCANROOT" 2>/dev/null \
  | grep -vE '/__pycache__/|/node_modules/|/\.git/|UPSTREAM-LICENSE|bin/glaw-doctor'; }
sec=0
# (a) live key/token formats (AKIA…EXAMPLE and obvious placeholders excluded)
if scan 'sk-[a-zA-Z0-9]{32,}|AIza[0-9A-Za-z_-]{35}|ghp_[a-zA-Z0-9]{36}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY' \
   | grep -vE 'EXAMPLE|placeholder|your.?key|xxxx|<your|process\.env|expect\(|test' | grep -q .; then
  bad "possible live secret/key in tree — run: grep -rIE 'sk-|AKIA|BEGIN .*PRIVATE KEY' (excluding tests/examples)"; sec=$((sec+1))
fi
# (b) credential files
if find "$SCANROOT" -path '*/__pycache__' -prune -o -path '*/node_modules' -prune -o \
     \( -name '*.key' -o -name '*.pem' -o -name '.env' -o -name '*.enc' -o -name '*token*.json' -o -name '*credentials*.json' \) -print 2>/dev/null \
   | grep -q .; then
  bad "credential file committed (.key/.pem/.env/.enc/token/credentials)"; sec=$((sec+1))
fi
# (c) personal / real-client case data (the leak that prompted this guard).
#     Specific identifiers only — generic legal terms (indigent, hardship) are
#     legitimate skill content and must NOT trip this.
if scan 'prieto_v_|_v_avila|monikavila|monica\.avila|case_20[0-9]{2}-[0-9]{4,6}\.(json|bd|md)|LAW_SKILLS_TEST' | grep -q .; then
  bad "real-client case data in tree (party names / case files)"; sec=$((sec+1))
fi
[ "$sec" = 0 ] && ok "no secrets, keys, or personal data committed"

echo "═══ RESULT ═══"
echo "  failures: $FAIL   warnings: $WARN"
[ "$FAIL" = 0 ] && { echo "  HEALTHY ✅"; exit 0; } || { echo "  PROBLEMS FOUND ❌"; exit 1; }
