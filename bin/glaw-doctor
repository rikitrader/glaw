#!/usr/bin/env bash
# glaw-doctor — GLAW health/smoke harness. Read-only. The automated check the firm
# was missing. Five assertions:
#   1. SKILLS RESOLVE  — every glaw/<x>/SKILL.md has valid frontmatter; every deployed
#                        /glaw-* command symlink resolves; deploy parity (setup ran).
#   2. TOOLS RUN       — every bin/glaw-* runs a safe smoke command without crashing.
#   3. NO DANGLING REFS— every /glaw-*, bin/glaw-*, lib/*, and mapped external skill
#                        referenced in firm-roster.md (and across all SKILL.md) exists.
#   4. SKILL CONTRACTS — every skill passes bin/glaw-test (frontmatter, name-parity,
#                        When-to-invoke, UPL line, non-empty allowed-tools).
#   5. CAPABILITY HONESTY— bin/glaw-capability-audit: no LoRA/EWC neural-learning
#                        capability is falsely marked LIVE without the training infra.
# Exit 0 = healthy, 1 = problems found.
set -uo pipefail
SCRIPT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ROOT="${GLAW_SKILLS_ROOT:-${CODEX_HOME:-$HOME/.codex}/skills}"
GLAW="${GLAW_SKILL_DIR:-$SCRIPT_ROOT}"
FAIL=0; WARN=0
ok(){ printf '  ✅ %s\n' "$1"; }
bad(){ printf '  ❌ %s\n' "$1"; FAIL=$((FAIL+1)); }
warn(){ printf '  ⚠️  %s\n' "$1"; WARN=$((WARN+1)); }

echo "═══ GLAW DOCTOR ═══"

# ---- 1. SKILLS RESOLVE ----
echo "[1/3] skills resolve"
src_skills=$(find -H "$GLAW" -name SKILL.md | wc -l | tr -d ' ')
deployed=$(ls -d "$ROOT"/glaw-*/ 2>/dev/null | wc -l | tr -d ' ')
# every source SKILL.md has name + description
nf=0
for f in $(find -H "$GLAW" -name SKILL.md); do
  grep -q '^name:' "$f" && grep -q '^description:' "$f" || { bad "missing frontmatter: ${f#$GLAW/}"; nf=$((nf+1)); }
done
[ "$nf" = 0 ] && ok "$src_skills source SKILL.md files, all have name+description"
# every deployed symlink resolves
dl=0
for d in "$ROOT"/glaw-*/; do
  [ -f "$d/SKILL.md" ] || { bad "dangling deploy: ${d}SKILL.md does not resolve"; dl=$((dl+1)); }
done
[ "$dl" = 0 ] && ok "$deployed deployed /glaw-* commands, all symlinks resolve"
# deploy parity: each sub-skill dir (not orchestrator) should be deployed as glaw-<dir>
miss=0
for d in "$GLAW"/*/; do
  name="$(basename "$d")"; [ -f "$d/SKILL.md" ] || continue
  [ -e "$ROOT/glaw-$name" ] || { warn "not deployed (run glaw-setup): glaw-$name"; miss=$((miss+1)); }
done
[ "$miss" = 0 ] && ok "deploy parity: every sub-skill is a top-level command"
seatmiss=0
if [ -d "$GLAW/seats" ]; then
  for d in "$GLAW"/seats/*/; do
    name="$(basename "$d")"; [ -f "$d/SKILL.md" ] || continue
    [ -f "$ROOT/$name/SKILL.md" ] || { bad "vendored seat not deployed: /$name"; seatmiss=$((seatmiss+1)); }
  done
fi
[ "$seatmiss" = 0 ] && ok "vendored seat deploy parity: every seat is a top-level command"

if [ -z "${GLAW_SKILLS_ROOT:-}" ]; then
  if python3 - "$GLAW" "${CODEX_HOME:-$HOME/.codex}/skills" "${CLAUDE_HOME:-$HOME/.claude}/skills" <<'PY'
import pathlib
import sys

glaw = pathlib.Path(sys.argv[1]).resolve()
roots = [
    ("Codex", pathlib.Path(sys.argv[2]).expanduser()),
    ("Claude", pathlib.Path(sys.argv[3]).expanduser()),
]

expected = {"glaw": (glaw / "SKILL.md").resolve()}
for child in sorted(glaw.iterdir()):
    if child.name == "seats" or not child.is_dir():
        continue
    skill = child / "SKILL.md"
    if skill.exists():
        expected[f"glaw-{child.name}"] = skill.resolve()
seats = glaw / "seats"
if seats.exists():
    for child in sorted(seats.iterdir()):
        skill = child / "SKILL.md"
        if skill.exists():
            expected.setdefault(child.name, skill.resolve())

failures = []
for label, root in roots:
    if not root.exists():
        failures.append(f"{label} skills root missing: {root}")
        continue
    actual_names = {
        p.name for p in root.glob("glaw*")
        if not p.name.startswith("glaw.backup.")
    }
    missing = sorted(set(expected) - actual_names)
    extra = sorted(actual_names - set(expected))
    for name in missing:
        failures.append(f"{label} missing /{name}")
    for name in extra:
        failures.append(f"{label} has unexpected GLAW command /{name}")
    for name, target in expected.items():
        skill = root / name / "SKILL.md"
        if not skill.exists():
            continue
        resolved = skill.resolve()
        if resolved != target:
            failures.append(
                f"{label} /{name} points to {resolved}, expected {target}"
            )

if failures:
    for failure in failures:
        print(failure)
    sys.exit(1)
print(f"{len(expected)} commands mirrored across Codex and Claude")
PY
  then
    ok "Codex/Claude mirror parity: $(python3 - "$GLAW" <<'PY'
import pathlib
import sys
glaw = pathlib.Path(sys.argv[1]).resolve()
names = {"glaw"}
for child in glaw.iterdir():
    if child.name != "seats" and child.is_dir() and (child / "SKILL.md").exists():
        names.add(f"glaw-{child.name}")
seats = glaw / "seats"
if seats.exists():
    for child in seats.iterdir():
        if (child / "SKILL.md").exists():
            names.add(child.name)
print(len(names))
PY
) commands resolve to the same GLAW source graph"
  else
    bad "Codex/Claude mirror parity failed"
  fi
fi

# ---- 2. TOOLS RUN ----
echo "[2/3] tools run (safe smoke)"
declare -a TOOLS=(
  "glaw|version" "glaw-bureau-score|weights" "glaw-tax-report|types"
  "glaw-irs-file|scaffold 1099-NEC" "glaw-court-scrape|--list __none__"
  "glaw-compliance-audit|" "glaw-doc-extract|" "glaw-exempt-org|" "glaw-assemble|"
  "glaw-accounting-control|"
  "glaw-policy|check"
  "glaw-headless|--goal doctor --json"
  "glaw-host|manifest --json"
  "glaw-mcp|tools --json"
  "glaw-extism|tool_metadata --json"
  "glaw-constitution-score|scaffold"
  "glaw-oversight|status --json"
  "glaw-rbac|check --operation audit --role AUDITOR --actor doctor"
  "glaw-conscience|check-call --command bin/glaw-intake"
  "glaw-loop|status"
  "glaw-learnings|stats" "glaw-reflect|"
  "glaw-contract-score|scaffold" "glaw-publish|" "glaw-redline|" "glaw-redline-docx|" "glaw-chief-decision|"
  "glaw-review-chain|" "glaw-adversarial|" "glaw-ethics|" "glaw-upl-check|" "glaw-citation-corpus|status" "glaw-citation-gate|" "glaw-groundedness|audit" "glaw-docket-gate|"
)
for entry in "${TOOLS[@]}"; do
  tool="${entry%%|*}"; args="${entry#*|}"
  bin="$GLAW/bin/$tool"
  [ -x "$bin" ] || { bad "$tool: not executable"; continue; }
  err=$("$bin" $args 2>&1 >/dev/null); rc=$?
  if echo "$err" | grep -qiE 'Traceback|ModuleNotFoundError|No such file|command not found|SyntaxError'; then
    bad "$tool: crashed — $(echo "$err" | grep -iE 'Error|Traceback' | head -1)"
  elif [ "$rc" -ge 126 ]; then
    bad "$tool: exit $rc"
  else
    ok "$tool ran (exit $rc)"
  fi
done
# glaw-cites needs stdin
if printf '' | "$GLAW/bin/glaw-cites" - >/dev/null 2>&1; then ok "glaw-cites ran"; else bad "glaw-cites failed"; fi
# bookkeeping engine + finance tools: zero-dependency mode uses source/local smokes.
if [ "${GLAW_FULL_BOOKKEEPING_SELFTEST:-0}" = "1" ]; then
  _BKPY="$(command -v python3)"
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_smoke.py" >/dev/null 2>&1; then
    ok "glaw-bank-ingest engine smoke passed (parse + dedup + Golden-Rule verify)"
  else
    bad "glaw-bank-ingest engine smoke FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_smoke.py"
  fi
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_finance.py" >/dev/null 2>&1; then
    ok "finance tools smoke passed (statements + books-doctor + bank-rec)"
  else
    bad "finance tools smoke FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_finance.py"
  fi
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_finance2.py" >/dev/null 2>&1; then
    ok "close-cycle tools smoke passed (depreciate + aging + cashflow + budget + monitor)"
  else
    bad "close-cycle tools smoke FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_finance2.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_ledger.py" >/dev/null 2>&1; then
    ok "general-ledger smoke passed (balanced JEs + non-cash + as-of + lock + close + audit)"
  else
    bad "general-ledger smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_ledger.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance3.py" >/dev/null 2>&1; then
    ok "reporting smoke passed (comparative + amortize + narrative)"
  else
    bad "reporting smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance3.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance5.py" >/dev/null 2>&1; then
    ok "tier 2/3 calc smoke passed (revrec + fx + inventory + tax-provision + consolidate + cash-apply + recurring)"
  else
    bad "tier 2/3 calc smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance5.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance6.py" >/dev/null 2>&1; then
    ok "dashboard KPI smoke passed (margins + liquidity + DSO/DPO + leverage)"
  else
    bad "dashboard KPI smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance6.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance7.py" >/dev/null 2>&1; then
    ok "scheduled-close smoke passed (clean → pass+lock, broken → fail+unlocked)"
  else
    bad "scheduled-close smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance7.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance8.py" >/dev/null 2>&1; then
    ok "tagged-COA + indirect cash flow smoke passed (reconciles to Δcash)"
  else
    bad "tagged-COA smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance8.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance9.py" >/dev/null 2>&1; then
    ok "subledger auto-post smoke passed (depreciation/deferred-rev/loan, idempotent)"
  else
    bad "subledger smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance9.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance10.py" >/dev/null 2>&1; then
    ok "JE forensics + Benford smoke passed (SAS-99 tests + first-digit analysis)"
  else
    bad "JE forensics smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance10.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance11.py" >/dev/null 2>&1; then
    ok "report export smoke passed (branded HTML — statements + cash flow + KPIs + MD&A)"
  else
    bad "report export smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance11.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance12.py" >/dev/null 2>&1; then
    ok "multi-account reconstruction smoke passed (transfers netted + continuity + tie-out)"
  else
    bad "reconstruction smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance12.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance13.py" >/dev/null 2>&1; then
    ok "reconstruction hardening smoke passed (opening balances + no-false-audit-ready + currency + cards)"
  else
    bad "reconstruction hardening smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance13.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance14.py" >/dev/null 2>&1; then
    ok "multi-currency GL smoke passed (per-currency balances + current-rate translation + CTA)"
  else
    bad "multi-currency smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance14.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance15.py" >/dev/null 2>&1; then
    ok "multi-entity NCI + equity-method smoke passed"
  else
    bad "NCI/equity-method smoke FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance15.py"
  fi
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_finance16.py" >/dev/null 2>&1; then
    ok "invoice/bill extractor smoke passed (vendor + line items + tax + draft AP entry)"
  else
    bad "invoice extractor smoke FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_finance16.py"
  fi
  if "$_BKPY" "$GLAW/lib/bookkeeping/test_glossary.py" >/dev/null 2>&1; then
    ok "accounting glossary smoke passed (terms indexed, core terms resolve)"
  else
    bad "accounting glossary smoke FAILED — run: $_BKPY $GLAW/lib/bookkeeping/test_glossary.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_tamper.py" >/dev/null 2>&1; then
    ok "tamper-evidence chain passed (detects edit / currency / deletion / insertion)"
  else
    bad "tamper-evidence FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_tamper.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_concurrency.py" >/dev/null 2>&1; then
    ok "ledger concurrency passed (flock serializes concurrent posts)"
  else
    bad "concurrency FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_concurrency.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_scale.py" >/dev/null 2>&1; then
    ok "ledger scale passed (entries memo + O(1) dedup, chain holds over 500)"
  else
    bad "scale FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_scale.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_index.py" >/dev/null 2>&1; then
    ok "balance index passed (index == full recompute, cross-process, self-healing)"
  else
    bad "balance-index FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_index.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance17.py" >/dev/null 2>&1; then
    ok "FX conversion passed (realized gain/loss, reporting-balanced, per-currency tracked)"
  else
    bad "FX-convert FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance17.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance18.py" >/dev/null 2>&1; then
    ok "tax provision wired to GL (pretax from P&L + posts the JE back)"
  else
    bad "tax-wire FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance18.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance19.py" >/dev/null 2>&1; then
    ok "book-to-tax M-1 engine passed (perm/temp derived from the GL)"
  else
    bad "book-to-tax FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance19.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance20.py" >/dev/null 2>&1; then
    ok "deferred-tax roll-forward passed (DTL/DTA balance + period movement)"
  else
    bad "deferred-tax FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance20.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance21.py" >/dev/null 2>&1; then
    ok "return-line mapping passed (1120/1065 lines off the GL, ties to provision)"
  else
    bad "return-map FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance21.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance22.py" >/dev/null 2>&1; then
    ok "MACRS depreciation passed (tables + 179/bonus + feeds the M-1)"
  else
    bad "MACRS FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance22.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance23.py" >/dev/null 2>&1; then
    ok "NOL carryforward passed (80% cap, FIFO, wired into the return)"
  else
    bad "NOL FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance23.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance24.py" >/dev/null 2>&1; then
    ok "K-1 allocation passed (pass-through split by ownership, ties out)"
  else
    bad "K-1 FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance24.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance25.py" >/dev/null 2>&1; then
    ok "QBI §199A passed (wage/UBIA limit + SSTB phase-out + income cap)"
  else
    bad "QBI FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance25.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance26.py" >/dev/null 2>&1; then
    ok "tax tie-out passed (posted provision ties; books-doctor [8/8] catches tampering)"
  else
    bad "tax-tieout FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance26.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance27.py" >/dev/null 2>&1; then
    ok "estimated tax passed (safe harbor + 2220/2210 underpayment)"
  else
    bad "estimated-tax FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance27.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance28.py" >/dev/null 2>&1; then
    ok "penalty & interest passed (FTF/FTP caps + daily-compounded interest)"
  else
    bad "penalties FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance28.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance29.py" >/dev/null 2>&1; then
    ok "1099-NEC from GL passed (vendor payments >= \$600 aggregated)"
  else
    bad "1099 FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance29.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance30.py" >/dev/null 2>&1; then
    ok "payroll tax passed (FICA + addl Medicare + FUTA/SUTA + 941)"
  else
    bad "payroll-tax FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance30.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance31.py" >/dev/null 2>&1; then
    ok "sales & use tax passed (economic nexus + GL reconciliation)"
  else
    bad "sales-use FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance31.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance32.py" >/dev/null 2>&1; then
    ok "state apportionment passed (3-factor / double-sales / single-sales)"
  else
    bad "apportion FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance32.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance33.py" >/dev/null 2>&1; then
    ok "tax credits passed (R&D §41 + FTC + general business credit limits)"
  else
    bad "credits FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance33.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance34.py" >/dev/null 2>&1; then
    ok "Form 1040 + Schedule SE passed (SE tax + brackets + assembly)"
  else
    bad "form1040 FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance34.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance35.py" >/dev/null 2>&1; then
    ok "ASC 740 footnote passed (rate reconciliation + FIN 48 UTP rollforward)"
  else
    bad "tax-footnote FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance35.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance36.py" >/dev/null 2>&1; then
    ok "statute of limitations passed (§6501 assessment + §6511 refund)"
  else
    bad "SOL FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance36.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance37.py" >/dev/null 2>&1; then
    ok "transcript analysis passed (account TC reconstruction + W&I income)"
  else
    bad "transcript FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance37.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance38.py" >/dev/null 2>&1; then
    ok "penalty abatement passed (FTA + reasonable cause → Form 843)"
  else
    bad "abatement FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance38.py"
  fi
  if GLAW_HOME="$(mktemp -d)" "$_BKPY" "$GLAW/lib/bookkeeping/test_finance39.py" >/dev/null 2>&1; then
    ok "audit package passed (GL substantiation + Form 4549 + IDR)"
  else
    bad "audit-package FAILED — run: GLAW_HOME=\$(mktemp -d) $_BKPY $GLAW/lib/bookkeeping/test_finance39.py"
