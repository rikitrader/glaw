#!/usr/bin/env bash
# glaw-estimated-tax — quarterly safe-harbor installments + Form 2220/2210 underpayment penalty.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/estimated_tax.py" "$@"
