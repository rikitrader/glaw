#!/usr/bin/env bash
# glaw-budget-vs-actual — variance analysis: a budget ({account: amount} JSON) vs
# actuals from a GLAW ledger (glaw-bank-ingest --format json). Flags expense
# over-runs and income shortfalls past --threshold. Exit 0 only if on budget.
#
# Usage:
#   glaw-bank-ingest stmt.csv --map coa.json --format json > actual.json
#   glaw-budget-vs-actual --budget budget.json --actual actual.json [--threshold 10]

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_LIB="$(cd "$SCRIPT_DIR/../lib/bookkeeping" && pwd)"
GLAW_LIB="${GLAW:+$GLAW/lib/bookkeeping}"
[ -n "${GLAW_LIB:-}" ] && [ -d "$GLAW_LIB" ] || GLAW_LIB="$SCRIPT_LIB"
PY="$(command -v python3)"
exec "$PY" "$GLAW_LIB/budget.py" "$@"
