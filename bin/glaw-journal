#!/usr/bin/env bash
# glaw-journal — post a balanced manual/adjusting journal entry to the general ledger.
#   glaw-journal --date 2026-01-31 --memo "Jan depreciation" \
#     --debit Expenses:Depreciation 1000 --credit "Assets:Accumulated Depreciation" 1000
# (alias for: glaw-ledger post)
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
BOOK=default; ARGS=()
while [[ $# -gt 0 ]]; do case "$1" in --book) BOOK="$2"; shift 2;; *) ARGS+=("$1"); shift;; esac; done
exec "$VENV_PY" "$GLAW_LIB/ledger_cli.py" --book "$BOOK" post ${ARGS[@]+"${ARGS[@]}"}
