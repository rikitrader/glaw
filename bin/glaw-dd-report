#!/usr/bin/env bash
#
# glaw-dd-report — thin bridge from GLAW into the due-diligence-agents
# HTML report engine. Renders a self-contained interactive HTML DD report
# from a findings JSON file.
#
# Usage:
#   glaw-dd-report <findings.json> <output.html> [--title "Report Title"]
#
# Input JSON may be either:
#   (A) merged_data shape:  { "<subject>": { "findings": [...], "gaps": [...] }, ... }
#   (B) a flat findings list: [ {finding}, {finding}, ... ]
#   (C) { "subject": "Name", "findings": [...], "gaps": [...] }
# Shapes (B) and (C) are wrapped into a single subject automatically.
#
# If the dd-agents package is not importable in the dd-venv, this prints
# honest install instructions and exits non-zero WITHOUT crashing.

set -euo pipefail

DD_VENV_PY="$HOME/.glaw/tools/dd-venv/bin/python"
DD_REPO="$HOME/.claude/skills-repos/due-diligence-agents"

print_install_help() {
  cat >&2 <<EOF
[glaw-dd-report] NOT AVAILABLE — the dd-agents report engine is not installed.

Reason: $1

Install steps:
  python3.12 -m venv $HOME/.glaw/tools/dd-venv
  $HOME/.glaw/tools/dd-venv/bin/pip install -e "$DD_REPO"

Then re-run:
  glaw-dd-report <findings.json> <output.html> [--title "..."]

Notes:
  - Requires Python 3.12 or 3.13 (the package pins requires-python >=3.12,
    and several deps lack 3.14 wheels).
  - HTML reporting does NOT need an ANTHROPIC_API_KEY; it is pure rendering.
EOF
}

# --- Preflight: venv python exists? ---
if [[ ! -x "$DD_VENV_PY" ]]; then
  print_install_help "dd-venv python not found at $DD_VENV_PY"
  exit 3
fi

# --- Preflight: package importable? ---
if ! "$DD_VENV_PY" -c "import dd_agents.reporting.html" >/dev/null 2>&1; then
  ERR="$("$DD_VENV_PY" -c "import dd_agents.reporting.html" 2>&1 | tail -1 || true)"
  print_install_help "dd_agents not importable in dd-venv ($ERR)"
  exit 3
fi

# --- Args ---
if [[ $# -lt 2 ]]; then
  echo "Usage: glaw-dd-report <findings.json> <output.html> [--title \"...\"]" >&2
  exit 2
fi

FINDINGS_JSON="$1"; shift
OUTPUT_HTML="$1"; shift
TITLE="Due Diligence Report"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --title) TITLE="${2:-}"; shift 2 ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

if [[ ! -f "$FINDINGS_JSON" ]]; then
  echo "[glaw-dd-report] findings file not found: $FINDINGS_JSON" >&2
  exit 2
fi

# --- Render via dd_agents ---
GLAW_DD_FINDINGS="$FINDINGS_JSON" \
GLAW_DD_OUTPUT="$OUTPUT_HTML" \
GLAW_DD_TITLE="$TITLE" \
"$DD_VENV_PY" - <<'PY'
import json
import os
import re
import sys
from pathlib import Path

from dd_agents.reporting.html import HTMLReportGenerator

findings_path = Path(os.environ["GLAW_DD_FINDINGS"])
output_path = Path(os.environ["GLAW_DD_OUTPUT"])
title = os.environ.get("GLAW_DD_TITLE", "Due Diligence Report")

raw = json.loads(findings_path.read_text(encoding="utf-8"))


def _safe_name(name: str) -> str:
    n = name.strip().lower()
    n = re.sub(r"[^a-z0-9]+", "_", n).strip("_")
    return n or "subject"


def _normalize(raw):
    """Coerce arbitrary input into merged_data: {safe_name: {findings, gaps}}."""
    # Shape (B): flat list of findings
    if isinstance(raw, list):
        return {"subject": {"findings": raw, "gaps": []}}
    if not isinstance(raw, dict):
        raise SystemExit(f"[glaw-dd-report] unsupported JSON top-level type: {type(raw).__name__}")
    # Shape (C): single subject object with findings/gaps at top level
    if "findings" in raw or "gaps" in raw:
        subj = raw.get("subject") or raw.get("entity") or "subject"
        return {
            _safe_name(str(subj)): {
                "findings": raw.get("findings", []),
                "gaps": raw.get("gaps", []),
            }
        }
    # Shape (A): already merged_data ({subject: {findings: [...]}})
    merged = {}
    for k, v in raw.items():
        if isinstance(v, dict):
            merged[_safe_name(str(k))] = {
                "findings": v.get("findings", []),
                "gaps": v.get("gaps", []),
            }
    if not merged:
        raise SystemExit("[glaw-dd-report] no subjects with findings found in input JSON")
    return merged


merged_data = _normalize(raw)

HTMLReportGenerator().generate(merged_data, output_path, title=title)

if output_path.exists() and output_path.stat().st_size > 0:
    print(f"[glaw-dd-report] OK — wrote {output_path} ({output_path.stat().st_size} bytes)")
else:
    raise SystemExit("[glaw-dd-report] generate() returned but no output file was produced")
PY
