#!/usr/bin/env bash
# glaw-form709 — Form 709 gift-tax DRAFT (annual exclusion, splitting, cumulative tax, GST flag).
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/form709.py" "$@"
