#!/usr/bin/env bash
# glaw-fbar-8938 — FBAR (FinCEN 114) + Form 8938 threshold determination and §962 election flag.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/fbar_8938.py" "$@"
