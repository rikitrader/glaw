#!/usr/bin/env bash
# glaw-payroll-tax — FICA + additional Medicare + employer match + FUTA/SUTA + Form 941 totals.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/payroll_tax.py" "$@"
