#!/usr/bin/env bash
# glaw-payroll-tax — FICA + additional Medicare + employer match + FUTA/SUTA + Form 941 totals.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_LIB="$(cd "$SCRIPT_DIR/../lib/bookkeeping" && pwd)"
GLAW_LIB="${GLAW:+$GLAW/lib/bookkeeping}"
[ -n "${GLAW_LIB:-}" ] && [ -d "$GLAW_LIB" ] || GLAW_LIB="$SCRIPT_LIB"
PY="$(command -v python3)"
exec "$PY" "$GLAW_LIB/payroll_tax.py" "$@"
