#!/usr/bin/env bash
# glaw-books-doctor — the bulletproof finance control gate. Consumes a GLAW ledger
# (glaw-bank-ingest --format json) and asserts the books are sound:
#   trial balance balances · BS identity · Golden Rule · classified · cash >= 0 ·
#   dedup intact · anomaly scan · (optional) reconciled. Exit 0 = bulletproof.
#
# Usage:
#   glaw-bank-ingest stmt.csv --map coa.json --open 0 --close N --format json | glaw-books-doctor -
#   glaw-books-doctor ledger.json [--allow-negative-cash] [--rec bank_rec.json]

set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
if [[ ! -x "$VENV_PY" ]]; then
  echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2
fi
exec "$VENV_PY" "$GLAW_LIB/books_doctor.py" "$@"
