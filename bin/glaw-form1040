#!/usr/bin/env bash
# glaw-form1040 — individual return: Schedule C → 1040 with Schedule SE self-employment tax.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/form1040.py" "$@"
