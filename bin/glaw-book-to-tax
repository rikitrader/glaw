#!/usr/bin/env bash
# glaw-book-to-tax — derive Schedule M-1 permanent/temporary differences from the posted GL.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/book_to_tax.py" "$@"
