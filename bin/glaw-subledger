#!/usr/bin/env bash
# glaw-subledger — registered schedules (fixed-asset/deferred-revenue/loan) that auto-post
# their period entry to the ledger. add-asset/add-deferred/add-loan/post/list.
set -euo pipefail
GLAW_LIB="$HOME/.claude/skills/glaw/lib/bookkeeping"
VENV_PY="$GLAW_LIB/.venv/bin/python"
[[ -x "$VENV_PY" ]] || { echo "ERROR: bookkeeping venv missing — run ./setup" >&2; exit 2; }
exec "$VENV_PY" "$GLAW_LIB/subledger.py" "$@"
