# GLAW — live matter run demo GIF.
# Regenerate: vhs demo/glaw-matter-run.tape  (outputs assets/glaw-matter-run.gif)
Output assets/glaw-matter-run.gif

Set Shell      bash
Set FontSize   18
Set Width      1000
Set Height     580
Set Padding    24
Set Theme      "Catppuccin Mocha"
Set PlaybackSpeed 1.0

Type "# /glaw  →  incorporate a FL holdco over my opco and lock down asset protection"
Sleep 500ms
Enter
Sleep 400ms
Type "./demo/glaw-matter-run.sh"
Sleep 400ms
Enter
Sleep 13s
